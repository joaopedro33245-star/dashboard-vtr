}

// ─── Modal de motivos do comparativo ─────────────────────────────────────────
function ComparativoClienteModal({ cliente, periodoKey, keyFn, labelFn, dispatchesFiltrados, tipoVisao, accentAtivo, onClose }) {
  if (!cliente) return null;
  const [obs, setObs] = useState("");
  const [salvandoObs, setSalvandoObs] = useState(false);
  const [obsCarregando, setObsCarregando] = useState(true);

  useEffect(() => {
    async function loadObs() {
      setObsCarregando(true);
      try {
        const { data } = await supaQuery(() =>
          supabaseClient.from("clients").select("observacao")
            .eq("codigo_cliente", cliente.codigo_cliente)
            .eq("filial", cliente.filial).single()
        );
        if (data) setObs(data.observacao||"");
      } catch(e) {
        toast("Erro ao carregar observação", "error");
      } finally {
        setObsCarregando(false);
      }
    }
    loadObs();
  }, [cliente.codigo_cliente, cliente.filial]);

  async function salvarObs() {
    setSalvandoObs(true);
    try {
      await supaQuery(() =>
        supabaseClient.from("clients").update({ observacao:obs })
          .eq("codigo_cliente", cliente.codigo_cliente)
          .eq("filial", cliente.filial)
      );
      toast("Observação salva com sucesso!", "success");
    } catch(e) {
      toast("Erro ao salvar observação: " + (e.message||"tente novamente"), "error");
    } finally {
      setSalvandoObs(false);
    }
  }

  const meusDeslocs = dispatchesFiltrados.filter(d => {
    const dt = parseDataHora(d.data_hora);
    if (!dt||keyFn(dt)!==periodoKey) return false;
    if (d.codigo_cliente!==cliente.codigo_cliente||d.filial!==cliente.filial) return false;
    if (tipoVisao==="normal"&&d.portaria_inteligente) return false;
    if (tipoVisao==="pi"&&!d.portaria_inteligente) return false;
    return true;
  });
  const eventoMap = {};
  for (const d of meusDeslocs) eventoMap[d.evento]=(eventoMap[d.evento]||0)+1;
  const eventos = Object.entries(eventoMap).sort((a,b)=>b[1]-a[1]);
  const total = meusDeslocs.length;

  return (
    <div style={{ position:"fixed",inset:0,background:"rgba(0,0,0,0.8)",zIndex:3000,display:"flex",alignItems:"center",justifyContent:"center",padding:16 }} onClick={onClose}>
      <div style={{ background:"#0f172a",border:"1px solid rgba(255,255,255,0.1)",borderRadius:20,width:"100%",maxWidth:620,maxHeight:"90vh",overflowY:"auto",padding:28 }} onClick={e=>e.stopPropagation()}>
        <div style={{ display:"flex",justifyContent:"space-between",alignItems:"flex-start",marginBottom:20 }}>
          <div>
            <div style={{ fontSize:17,fontWeight:700,color:"#fff",marginBottom:4 }}>{cliente.nome_cliente}</div>
            <div style={{ fontSize:11,color:"rgba(255,255,255,0.4)" }}>Cód. {cliente.codigo_cliente} · {cliente.filial}</div>
            <div style={{ marginTop:6,display:"inline-flex",alignItems:"center",gap:6,padding:"3px 10px",borderRadius:99,background:`${accentAtivo}18`,border:`1px solid ${accentAtivo}40`,fontSize:11,fontWeight:700,color:accentAtivo }}>
              📅 {labelFn(periodoKey)} · {total} eventos
            </div>
          </div>
          <button onClick={onClose} style={{ background:"rgba(255,255,255,0.08)",border:"none",color:"#fff",borderRadius:8,padding:"6px 14px",cursor:"pointer",fontSize:13 }}>✕</button>
        </div>
        {eventos.length===0 ? (
          <div style={{ textAlign:"center",padding:32,color:"rgba(255,255,255,0.3)",fontSize:13 }}>Nenhum evento encontrado</div>
        ) : (
          <div style={{ marginBottom:20 }}>
            <div style={{ fontSize:10,fontWeight:700,letterSpacing:"0.15em",textTransform:"uppercase",color:"rgba(255,255,255,0.35)",marginBottom:14 }}>Motivos dos Deslocamentos</div>
            <div style={{ display:"flex",flexDirection:"column",gap:10 }}>
              {eventos.map(([evt,cnt],i) => {
                const pct = total>0?Math.round((cnt/total)*100):0;
                return (
                  <div key={i}>
                    <div style={{ display:"flex",justifyContent:"space-between",marginBottom:5 }}>
                      <span style={{ fontSize:12,color:"rgba(255,255,255,0.8)",display:"flex",alignItems:"center",gap:7 }}>
                        <span style={{ width:8,height:8,borderRadius:"50%",background:CHART_COLORS[i%CHART_COLORS.length],flexShrink:0,display:"inline-block" }} />{evt}
                      </span>
                      <span style={{ fontSize:12,fontWeight:700,color:CHART_COLORS[i%CHART_COLORS.length],marginLeft:12,flexShrink:0 }}>{cnt}x · {pct}%</span>
                    </div>
                    <div style={{ height:5,borderRadius:999,background:"rgba(255,255,255,0.06)" }}>
                      <div style={{ height:"100%",width:`${pct}%`,borderRadius:999,background:CHART_COLORS[i%CHART_COLORS.length] }} />
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        )}
        <div style={{ marginBottom:20 }}>
          <div style={{ fontSize:10,fontWeight:700,letterSpacing:"0.15em",textTransform:"uppercase",color:"rgba(255,255,255,0.35)",marginBottom:10 }}>Observação / Acompanhamento</div>
          {obsCarregando ? <Skeleton height={88} radius={10} /> : (
            <textarea value={obs} onChange={e=>setObs(e.target.value)}
              placeholder="Ex: Cliente com sensor defeituoso, aguardando visita técnica..."
              style={{ width:"100%",minHeight:88,background:"rgba(255,255,255,0.05)",border:"1px solid rgba(255,255,255,0.1)",borderRadius:10,padding:"10px 14px",color:"#fff",fontSize:13,resize:"vertical",outline:"none",fontFamily:"inherit",lineHeight:1.5 }}
              onFocus={e=>e.target.style.borderColor=accentAtivo}
              onBlur={e=>e.target.style.borderColor="rgba(255,255,255,0.1)"} />
          )}
          <div style={{ display:"flex",justifyContent:"flex-end",marginTop:8 }}>
            <LoadingBtn onClick={salvarObs} loading={salvandoObs} color={accentAtivo}>
              Salvar Observação
            </LoadingBtn>
          </div>
        </div>
        {meusDeslocs.length>0 && (
          <div>
            <div style={{ fontSize:10,fontWeight:700,letterSpacing:"0.15em",textTransform:"uppercase",color:"rgba(255,255,255,0.35)",marginBottom:12 }}>Histórico ({meusDeslocs.length})</div>
            <div style={{ display:"flex",flexDirection:"column",gap:5,maxHeight:200,overflowY:"auto" }}>
              {meusDeslocs.map((d,i) => (
                <div key={i} style={{ display:"flex",justifyContent:"space-between",padding:"7px 12px",background:"rgba(255,255,255,0.03)",borderRadius:8,fontSize:11 }}>
                  <span style={{ color:"rgba(255,255,255,0.75)" }}>{d.evento}</span>
                  <div style={{ display:"flex",gap:14,color:"rgba(255,255,255,0.3)",flexShrink:0,marginLeft:12 }}>
                    <span>{d.viatura}</span><span>{d.data_hora}</span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>
  );
}

// ─── Comparativos ─────────────────────────────────────────────────────────────
function ComparativosPeriodo({ dispatches, dispatchesFiltrados, tipoVisao, periodoTipo }) {
  const isWeek = periodoTipo==="semana";
  const [periodoA, setPeriodoA] = useState("");
  const [periodoB, setPeriodoB] = useState("");
  const [clienteModal, setClienteModal] = useState(null);

  const periodos = useMemo(() => {
    const s = new Set();
    for (const d of dispatchesFiltrados) {
      const dt = parseDataHora(d.data_hora);
      if (dt) s.add(isWeek?getWeekKey(dt):getMonthKey(dt));
    }
    return Array.from(s).filter(Boolean).sort().reverse();
  }, [dispatchesFiltrados, isWeek]);

  useEffect(() => { setPeriodoA(""); setPeriodoB(""); }, [periodoTipo]);
  useEffect(() => {
    if (periodos.length>0&&!periodoA) setPeriodoA(periodos[0]);
    if (periodos.length>1&&!periodoB) setPeriodoB(periodos[1]);
  }, [periodos]);

  const labelFn = isWeek?weekLabel:monthLabel;
  const keyFn   = isWeek?getWeekKey:getMonthKey;
  const accentNormal = isWeek?"#38bdf8":"#fb923c";
  const accentPI     = "#a78bfa";

  function buildData(periodoKey, tipo) {
    if (!periodoKey) return { clientes:[], total:0 };
    const clienteMap = {};
    for (const d of dispatchesFiltrados) {
      const dt = parseDataHora(d.data_hora);
      if (!dt||keyFn(dt)!==periodoKey) continue;
      if (tipo==="normal"&&d.portaria_inteligente) continue;
      if (tipo==="pi"&&!d.portaria_inteligente) continue;
      const key = `${d.codigo_cliente}||${d.filial}`;
      if (!clienteMap[key]) clienteMap[key]={ codigo_cliente:d.codigo_cliente, nome_cliente:d.nome_cliente||d.codigo_cliente, filial:d.filial, total:0 };
      clienteMap[key].total++;
    }
    const clientes = Object.values(clienteMap).sort((a,b)=>b.total-a.total);
    return { clientes, total:clientes.reduce((s,c)=>s+c.total,0) };
  }

  const dataA_normal = useMemo(()=>buildData(periodoA,"normal"),[periodoA,dispatchesFiltrados]);
  const dataB_normal = useMemo(()=>buildData(periodoB,"normal"),[periodoB,dispatchesFiltrados]);
  const dataA_pi     = useMemo(()=>buildData(periodoA,"pi"),    [periodoA,dispatchesFiltrados]);
  const dataB_pi     = useMemo(()=>buildData(periodoB,"pi"),    [periodoB,dispatchesFiltrados]);

  const dataA_ativo = tipoVisao==="pi"?dataA_pi:dataA_normal;
  const dataB_ativo = tipoVisao==="pi"?dataB_pi:dataB_normal;
  const accentAtivo = tipoVisao==="pi"?accentPI:accentNormal;
  const iconeAtivo  = tipoVisao==="pi"?"🏢":"🚗";
  const labelTipo   = tipoVisao==="pi"?"Portaria Inteligente":"Deslocamentos Normais";

  const variacaoA = dataA_ativo.total;
  const variacaoB = dataB_ativo.total;
  const variacao  = variacaoA&&variacaoB?Math.round(((variacaoA-variacaoB)/variacaoB)*100):null;

  const evolucaoData = useMemo(() => {
    const clienteMap = {};
    for (const d of dispatchesFiltrados) {
      if (tipoVisao==="normal"&&d.portaria_inteligente) continue;
      if (tipoVisao==="pi"&&!d.portaria_inteligente) continue;
      const key = `${d.codigo_cliente}||${d.filial}`;
      if (!clienteMap[key]) clienteMap[key]={ codigo:d.codigo_cliente, nome:d.nome_cliente||d.codigo_cliente, filial:d.filial, periodos:{} };
      const dt = parseDataHora(d.data_hora);
      if (!dt) continue;
      const pk = keyFn(dt);
      if (!pk) continue;
      clienteMap[key].periodos[pk]=(clienteMap[key].periodos[pk]||0)+1;
    }
    const clientes = Object.values(clienteMap)
      .map(c=>({ ...c, total:Object.values(c.periodos).reduce((s,v)=>s+v,0) }))
      .sort((a,b)=>b.total-a.total).slice(0,15);
    return { clientes, periodos:periodos.slice(0,isWeek?8:12) };
  }, [dispatchesFiltrados,periodos,tipoVisao,isWeek]);

  if (periodos.length===0) return <EmptyState icon="📅" title="Datas não encontradas" sub="Os deslocamentos importados não contêm datas reconhecíveis." />;

  const selStyle = { padding:"9px 14px",borderRadius:10,border:"1px solid rgba(255,255,255,0.12)",background:"rgba(255,255,255,0.06)",color:"#fff",fontSize:13,outline:"none",cursor:"pointer" };
  const labelPeriodo = isWeek?"Semana":"Mês";

  return (
    <div>
      <div style={{ fontSize:12,color:"rgba(255,255,255,0.35)",marginBottom:20 }}>
        {periodos.length} {isWeek?"semanas":"meses"} disponíveis ·
        <span style={{ marginLeft:6,color:accentAtivo,fontWeight:600 }}>{tipoVisao==="pi"?"🏢 Portaria Inteligente":tipoVisao==="ambos"?"🔀 Normal + PI":"🚗 Normal"}</span>
      </div>
      <div style={{ marginBottom:28 }}>
        <SectionLabel>Comparação Lado a Lado</SectionLabel>
        <div style={{ display:"grid",gridTemplateColumns:"1fr auto 1fr",gap:16,alignItems:"center",marginBottom:20 }}>
          <div style={{ borderRadius:14,border:`1px solid ${accentAtivo}40`,background:`${accentAtivo}08`,padding:"14px 18px" }}>
            <div style={{ fontSize:10,fontWeight:700,letterSpacing:"0.12em",textTransform:"uppercase",color:accentAtivo,marginBottom:8 }}>{labelPeriodo} A</div>
            <select value={periodoA} onChange={e=>setPeriodoA(e.target.value)} style={{ ...selStyle,width:"100%",border:`1px solid ${accentAtivo}40`,background:`${accentAtivo}12`,color:accentAtivo,fontWeight:700 }}>
              {periodos.map(p=><option key={p} value={p}>{labelFn(p)}</option>)}
            </select>
          </div>
          <div style={{ textAlign:"center" }}>
            <div style={{ fontSize:22,color:"rgba(255,255,255,0.2)" }}>⇄</div>
            {variacao!==null && (
              <div style={{ fontSize:12,fontWeight:700,color:variacao>0?"#f87171":"#34d399",marginTop:4 }}>
                {variacao>0?"▲":"▼"} {Math.abs(variacao)}%
              </div>
            )}
          </div>
          <div style={{ borderRadius:14,border:"1px solid rgba(167,139,250,0.3)",background:"rgba(167,139,250,0.05)",padding:"14px 18px" }}>
            <div style={{ fontSize:10,fontWeight:700,letterSpacing:"0.12em",textTransform:"uppercase",color:"#a78bfa",marginBottom:8 }}>{labelPeriodo} B</div>
            <select value={periodoB} onChange={e=>setPeriodoB(e.target.value)} style={{ ...selStyle,width:"100%",border:"1px solid rgba(167,139,250,0.3)",background:"rgba(167,139,250,0.08)",color:"#a78bfa",fontWeight:700 }}>
              {periodos.map(p=><option key={p} value={p}>{labelFn(p)}</option>)}
            </select>
          </div>
        </div>
        <div style={{ display:"grid",gridTemplateColumns:"1fr 1fr",gap:16 }}>
          {[
            { periodoKey:periodoA, data:dataA_ativo, cor:accentAtivo, lado:"A", piData:dataA_pi },
            { periodoKey:periodoB, data:dataB_ativo, cor:"#a78bfa",   lado:"B", piData:dataB_pi },
          ].map(({ periodoKey,data,cor,lado,piData }) => (
            <Card key={lado}>
              <div style={{ padding:"14px 18px",borderBottom:"1px solid rgba(255,255,255,0.06)",display:"flex",justifyContent:"space-between",alignItems:"center" }}>
                <div>
                  <span style={{ fontSize:10,fontWeight:700,letterSpacing:"0.12em",textTransform:"uppercase",color:cor }}>{labelPeriodo} {lado}</span>
                  <div style={{ fontSize:13,fontWeight:700,color:"#fff",marginTop:2 }}>{labelFn(periodoKey)}</div>
                  <div style={{ fontSize:10,color:"rgba(255,255,255,0.3)",marginTop:2 }}>{iconeAtivo} {labelTipo}</div>
                </div>
                <div style={{ textAlign:"right" }}>
                  <div style={{ fontSize:22,fontWeight:800,color:cor }}>{data.total}</div>
                  <div style={{ fontSize:10,color:"rgba(255,255,255,0.3)" }}>eventos</div>
                </div>
              </div>
              <div style={{ maxHeight:340,overflowY:"auto" }}>
                {data.clientes.length===0 ? (
                  <div style={{ padding:24,textAlign:"center",color:"rgba(255,255,255,0.25)",fontSize:12 }}>Nenhum dado neste período</div>
                ) : data.clientes.slice(0,10).map((c,i) => {
                  const pct = Math.round((c.total/(data.clientes[0]?.total||1))*100);
                  return (
                    <div key={i} onClick={()=>setClienteModal({cliente:c,periodoKey})}
                      style={{ padding:"10px 18px",borderBottom:"1px solid rgba(255,255,255,0.04)",cursor:"pointer",transition:"background 0.15s" }}
                      onMouseEnter={e=>e.currentTarget.style.background=`${cor}10`}
                      onMouseLeave={e=>e.currentTarget.style.background="transparent"}>
                      <div style={{ display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:5 }}>
                        <div style={{ display:"flex",alignItems:"center",gap:8,flex:1,minWidth:0 }}>
                          <span style={{ fontSize:11,fontWeight:800,color:cor,minWidth:20 }}>#{i+1}</span>
                          <div style={{ minWidth:0 }}>
                            <div style={{ fontSize:12,fontWeight:600,color:cor,whiteSpace:"nowrap",overflow:"hidden",textOverflow:"ellipsis" }}>{c.nome_cliente}</div>
                            <div style={{ fontSize:10,color:"rgba(255,255,255,0.3)",fontFamily:"monospace" }}>{c.codigo_cliente}</div>
                          </div>
                        </div>
                        <span style={{ fontSize:15,fontWeight:800,color:cor,marginLeft:8,flexShrink:0 }}>{c.total}</span>
                      </div>
                      <div style={{ height:3,borderRadius:999,background:"rgba(255,255,255,0.06)" }}>
                        <div style={{ height:"100%",width:`${pct}%`,borderRadius:999,background:cor,opacity:0.7 }} />
                      </div>
                    </div>
                  );
                })}
              </div>
            </Card>
          ))}
        </div>
      </div>
      <EvolucaoTable data={evolucaoData} labelFn={labelFn} periodLabel={isWeek?"semana":"mês"} accentColor={accentAtivo} tipoVisao={tipoVisao} />
      {clienteModal && (
        <ComparativoClienteModal
          cliente={clienteModal.cliente} periodoKey={clienteModal.periodoKey}
          keyFn={keyFn} labelFn={labelFn} dispatchesFiltrados={dispatchesFiltrados}
          tipoVisao={tipoVisao} accentAtivo={accentAtivo}
          onClose={()=>setClienteModal(null)} />
      )}
    </div>
  );
}

function ComparativosSemanas({ dispatches, filiais, dispatchesFiltrados, tipoVisao }) {
  return <ComparativosPeriodo dispatches={dispatches} dispatchesFiltrados={dispatchesFiltrados} tipoVisao={tipoVisao} periodoTipo="semana" />;
}
function ComparativosMeses({ dispatches, dispatchesFiltrados, tipoVisao }) {
  return <ComparativosPeriodo dispatches={dispatches} dispatchesFiltrados={dispatchesFiltrados} tipoVisao={tipoVisao} periodoTipo="mes" />;
}

