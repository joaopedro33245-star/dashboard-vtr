    .toast-warning { background:rgba(251,146,60,0.15); border:1px solid rgba(251,146,60,0.4); color:#fb923c; }
    .toast-info    { background:rgba(56,189,248,0.15); border:1px solid rgba(56,189,248,0.4); color:#38bdf8; }

