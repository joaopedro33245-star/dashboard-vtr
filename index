                        {val>0 ? (
                          <div style={{ display:"flex",flexDirection:"column",alignItems:"center",gap:2 }}>
                            <div style={{ width:32,height:24,borderRadius:6,background:`rgba(${bgBase},${0.1+intensity*0.6})`,display:"flex",alignItems:"center",justifyContent:"center",fontSize:12,fontWeight:700,color:intensity>0.5?"#fff":accentColor }}>{val}</div>
                            {trend&&<span style={{ fontSize:9,color:trendColor }}>{trend}</span>}
                          </div>
                        ) : <span style={{ color:"rgba(255,255,255,0.1)",fontSize:11 }}>—</span>}
                      </td>
                    );
                  })}
                </tr>
              );
            })}
          </tbody>
        </table>
      </Card>
    </div>
  );
}

function ComparativosTab({ dispatches }) {
  const [subAba, setSubAba] = useState("semanas");
  const [filialFiltro, setFilialFiltro] = useState("Todas");
  const [tipoVisao, setTipoVisao] = useState("normal");

  const filiais = useMemo(() => {
    const s = new Set(dispatches.map(d=>d.filial).filter(Boolean));
    return ["Todas",...Array.from(s).sort()];
  }, [dispatches]);

  const dispatchesFiltrados = useMemo(() => {
    if (filialFiltro==="Todas") return dispatches;
    return dispatches.filter(d=>d.filial===filialFiltro);
  }, [dispatches,filialFiltro]);

  if (dispatches.length===0) return <EmptyState icon="📅" title="Nenhum dado para comparar" sub="Importe deslocamentos com data para visualizar os comparativos." />;

  const selStyle = { padding:"9px 14px",borderRadius:10,border:"1px solid rgba(255,255,255,0.12)",background:"rgba(255,255,255,0.06)",color:"#fff",fontSize:13,outline:"none",cursor:"pointer" };

