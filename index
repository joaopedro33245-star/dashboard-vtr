function RelatoriosTab({ clients, dispatches }) {
  const [filialFiltro, setFilialFiltro] = useState("Todas");
  const [statusFiltro, setStatusFiltro] = useState("Todos");
  const [busca, setBusca]               = useState("");
  const [clienteSelecionado, setClienteSelecionado] = useState(null);

  const dispMap = useMemo(()=>{
    const m={};
    for (const d of dispatches.filter(x=>!x.portaria_inteligente)) {
      const k=`${d.codigo_cliente}||${d.filial}`;
      m[k]=(m[k]||0)+1;
    }
    return m;
  },[dispatches]);

  const filiais = useMemo(()=>{ const s=new Set(clients.map(c=>c.filial).filter(Boolean)); return ["Todas",...Array.from(s).sort()]; },[clients]);

  const relatorio = useMemo(()=>clients.map(c=>{
    const desl=dispMap[`${c.codigo_cliente}||${c.filial}`]||0;
    const custo=desl*CUSTO_FISCAL;
    const mens=parseFloat(c.mensalidade)||0;
    return { ...c, desl, custo, mens, resultado:mens-custo, status:calcStatus(mens,custo) };
  }),[clients,dispMap]);

  const filtrado = useMemo(()=>relatorio.filter(c=>{
    if (filialFiltro!=="Todas"&&c.filial!==filialFiltro) return false;
    if (statusFiltro==="Prejuízo"&&c.status!=="PREJUÍZO") return false;
    if (statusFiltro==="Risco"&&c.status!=="RISCO") return false;
    if (statusFiltro==="Saudável"&&c.status!=="SAUDÁVEL") return false;
    if (statusFiltro==="Sem dados"&&c.status!=="SEM DADOS") return false;
    if (busca) {
      const b=busca.toLowerCase();
      if (!(c.nome_cliente||"").toLowerCase().includes(b)&&!String(c.codigo_cliente).includes(b)) return false;
    }
    return true;
  }).sort((a,b)=>b.desl-a.desl),[relatorio,filialFiltro,statusFiltro,busca]);

  const totais = useMemo(()=>({
    clientes:filtrado.length,
    desl:filtrado.reduce((s,c)=>s+c.desl,0),
    custo:filtrado.reduce((s,c)=>s+c.custo,0),
    mensalidade:filtrado.reduce((s,c)=>s+c.mens,0),
    resultado:filtrado.reduce((s,c)=>s+(c.mens>0?c.resultado:0),0),
    prejuizo:filtrado.filter(c=>c.status==="PREJUÍZO").length,
    risco:filtrado.filter(c=>c.status==="RISCO").length,
  }),[filtrado]);

  function exportarCSV() {
    const header="Código,Nome,Filial,Mensalidade,Deslocamentos,Custo,Resultado,Status";
    const rows=filtrado.map(c=>`${c.codigo_cliente},"${(c.nome_cliente||"").replace(/"/g,'""')}","${c.filial}",${c.mens},${c.desl},${c.custo},${c.resultado},${c.status}`);
    const csv=[header,...rows].join("\n");
    const blob=new Blob([csv],{ type:"text/csv;charset=utf-8;" });
    const url=URL.createObjectURL(blob);
    const a=document.createElement("a"); a.href=url; a.download="relatorio.csv"; a.click();
    URL.revokeObjectURL(url);
    toast("Relatório exportado com sucesso!", "success");
  }

  const iStyle={ padding:"9px 12px",background:"rgba(255,255,255,0.06)",border:"1px solid rgba(255,255,255,0.1)",borderRadius:8,color:"#fff",fontSize:13,outline:"none" };

  return (
    <div>
        <div style={{ display:"flex",justifyContent:"space-between",alignItems:"flex-start",marginBottom:20,flexWrap:"wrap",gap:12 }}>
          <div>
            <div style={{ fontSize:20,fontWeight:700 }}>📋 Relatório de Rentabilidade</div>
            <div style={{ fontSize:12,color:"rgba(255,255,255,0.4)",marginTop:2 }}>{filtrado.length} clientes · {totais.desl} deslocamentos</div>
          </div>
          <div style={{ display:"flex", gap:10 }}>
            <button onClick={()=>exportarPDF({ clients:filtrado, dispatches, filialFiltro, periodoLabel:"Período completo" })}
              style={{ background:"rgba(129,140,248,0.15)",border:"1px solid rgba(129,140,248,0.3)",color:"#818cf8",borderRadius:10,padding:"8px 16px",cursor:"pointer",fontSize:13,fontWeight:600 }}>
              📄 Exportar PDF
            </button>
            <button onClick={exportarCSV} style={{ background:"rgba(251,146,60,0.15)",border:"1px solid rgba(251,146,60,0.3)",color:"#fb923c",borderRadius:10,padding:"8px 16px",cursor:"pointer",fontSize:13,fontWeight:600 }}>⬇ Exportar CSV</button>
          </div>
        </div>
      <div style={{ display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(150px,1fr))",gap:12,marginBottom:20 }}>
        {[
          { label:"Total Mensalidade", val:`R$ ${totais.mensalidade.toLocaleString("pt-BR",{minimumFractionDigits:2})}`, color:"#34d399" },
          { label:"Custo Operacional", val:`R$ ${totais.custo.toLocaleString("pt-BR")}`, color:"#f472b6" },
          { label:"Resultado Líquido", val:`R$ ${totais.resultado.toLocaleString("pt-BR")}`, color:totais.resultado>=0?"#34d399":"#f87171" },
          { label:"Em Prejuízo", val:totais.prejuizo, color:"#f87171" },
          { label:"Em Risco", val:totais.risco, color:"#fbbf24" },
        ].map((k,i)=>(
          <div key={i} style={{ background:"rgba(255,255,255,0.04)",borderRadius:12,padding:"14px 16px",textAlign:"center",border:"1px solid rgba(255,255,255,0.05)" }}>
            <div style={{ fontSize:18,fontWeight:800,color:k.color }}>{k.val}</div>
            <div style={{ fontSize:11,color:"rgba(255,255,255,0.4)",marginTop:4 }}>{k.label}</div>
          </div>
        ))}
      </div>
      <div style={{ display:"flex",gap:10,marginBottom:16,flexWrap:"wrap" }}>
        <input placeholder="Buscar cliente..." value={busca} onChange={e=>setBusca(e.target.value)} style={{ ...iStyle,flex:1,minWidth:200 }} />
        <select value={filialFiltro} onChange={e=>setFilialFiltro(e.target.value)} style={iStyle}>{filiais.map(f=><option key={f} value={f}>{f}</option>)}</select>
        <select value={statusFiltro} onChange={e=>setStatusFiltro(e.target.value)} style={iStyle}>
          {["Todos","Prejuízo","Risco","Saudável","Sem dados"].map(s=><option key={s} value={s}>{s}</option>)}
        </select>
      </div>
      <Card style={{ overflow:"hidden" }}>
        <div style={{ overflowX:"auto" }}>
          <table style={{ width:"100%",borderCollapse:"collapse",fontSize:13 }}>
            <thead>
              <tr style={{ borderBottom:"1px solid rgba(255,255,255,0.07)" }}>
                {["Código","Nome do Cliente","Filial","Mensalidade","Deslocamentos","Custo","Resultado","Status"].map((h,i)=>(
                  <th key={i} style={{ padding:"12px 16px",textAlign:i<=1?"left":"center",color:"rgba(255,255,255,0.4)",fontWeight:600,fontSize:11,letterSpacing:0.5,whiteSpace:"nowrap" }}>{h}</th>
                ))}
              </tr>
            </thead>
            <tbody>
              {filtrado.length===0&&<tr><td colSpan={8} style={{ padding:40,textAlign:"center",color:"rgba(255,255,255,0.3)" }}>Nenhum cliente encontrado</td></tr>}
              {filtrado.map((c,i)=>{
                const cfg=STATUS_CONFIG[c.status]||STATUS_CONFIG["SEM DADOS"];
                return (
                  <tr key={i} onClick={()=>setClienteSelecionado(c)}
