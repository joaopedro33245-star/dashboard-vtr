function UsuariosTab({ usuarioAtual }) {
  const [usuarios, setUsuarios] = useState([]);
  const [loading, setLoading]   = useState(true);
  const [showForm, setShowForm] = useState(false);
  const [form, setForm]         = useState({ nome:"", email:"", senha:"", perfil:"viewer" });
  const [formErro, setFormErro] = useState("");
  const [salvando, setSalvando] = useState(false);
  const [editId, setEditId]     = useState(null);
  const [confirmarDel, setConfirmarDel] = useState(null);

  async function carregarUsuarios() {
    setLoading(true);
    try {
      const { data } = await supaQuery(()=>supabaseClient.from("profiles").select("*").order("created_at"));
      setUsuarios(data||[]);
    } catch(e) {
      toast("Erro ao carregar usuários: " + e.message, "error");
    } finally {
      setLoading(false);
    }
  }
  useEffect(()=>{ carregarUsuarios(); },[]);

  async function salvar() {
    setFormErro(""); setSalvando(true);
    if (!form.nome.trim()) { setFormErro("Nome é obrigatório."); setSalvando(false); return; }
    if (!form.email.trim()) { setFormErro("E-mail é obrigatório."); setSalvando(false); return; }
    try {
      if (editId) {
        await supaQuery(()=>supabaseClient.from("profiles").update({ nome:form.nome, perfil:form.perfil }).eq("id",editId));
        toast("Usuário atualizado com sucesso!", "success");
      } else {
        if (!form.senha.trim()||form.senha.length<6) { setFormErro("Senha deve ter ao menos 6 caracteres."); setSalvando(false); return; }
        const { data, error } = await supabaseClient.auth.signUp({ email:form.email, password:form.senha, options:{ data:{ nome:form.nome, perfil:form.perfil } } });
        if (error) throw error;
        if (data?.user) await supabaseClient.from("profiles").upsert([{ id:data.user.id, nome:form.nome, perfil:form.perfil }]);
        toast("Usuário criado! E-mail de confirmação enviado.", "success");
      }
      await carregarUsuarios();
      setShowForm(false); setEditId(null);
      setForm({ nome:"", email:"", senha:"", perfil:"viewer" });
    } catch(e) {
      setFormErro("Erro: " + (e.message||"tente novamente"));
      toast("Erro ao salvar usuário", "error");
    } finally {
      setSalvando(false);
    }
  }

  async function excluir(id) {
    try {
      await supaQuery(()=>supabaseClient.from("profiles").delete().eq("id",id));
      toast("Usuário removido.", "success");
      await carregarUsuarios();
    } catch(e) {
      toast("Erro ao excluir: " + e.message, "error");
    }
    setConfirmarDel(null);
  }

  function editar(u) { setForm({ nome:u.nome, email:u.email||"", senha:"", perfil:u.perfil }); setEditId(u.id); setShowForm(true); setFormErro(""); }
  const perfilStyle={ admin:{ label:"Admin", color:"#f87171", bg:"#ef444420", border:"#ef444440" }, viewer:{ label:"Visualizador", color:"#38bdf8", bg:"#38bdf820", border:"#38bdf840" } };

  return (
    <div>
      <div style={{ display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:20 }}>
        <div>
          <div style={{ fontSize:10,fontWeight:700,letterSpacing:"0.15em",textTransform:"uppercase",color:"rgba(255,255,255,0.35)" }}>Gerenciamento</div>
          <div style={{ fontSize:18,fontWeight:800,color:"#fff" }}>Usuários do Sistema</div>
        </div>
        <button onClick={()=>{ setShowForm(true); setEditId(null); setForm({ nome:"",email:"",senha:"",perfil:"viewer" }); setFormErro(""); }}
          style={{ padding:"9px 18px",borderRadius:10,border:"none",background:"#38bdf8",color:"#0a0f1a",fontWeight:700,fontSize:13,cursor:"pointer" }}>
          + Novo Usuário
        </button>
      </div>
      {showForm&&(
        <div style={{ borderRadius:16,border:"1px solid rgba(56,189,248,0.2)",background:"rgba(56,189,248,0.04)",padding:24,marginBottom:20 }}>
          <div style={{ fontSize:14,fontWeight:700,color:"#fff",marginBottom:20 }}>{editId?"✏️ Editar Usuário":"➕ Novo Usuário"}</div>
          <div style={{ display:"grid",gridTemplateColumns:"1fr 1fr",gap:14,marginBottom:14 }}>
            {[
              { label:"Nome completo", key:"nome", type:"text", placeholder:"Ex: João Silva" },
              { label:"E-mail", key:"email", type:"email", placeholder:"Ex: joao@empresa.com", disabled:!!editId },
              ...(!editId?[{ label:"Senha (mín. 6 caracteres)", key:"senha", type:"password", placeholder:"••••••••" }]:[]),
            ].map(({ label,key,type,placeholder,disabled })=>(
              <div key={key}>
                <label style={{ fontSize:11,fontWeight:600,textTransform:"uppercase",letterSpacing:"0.08em",color:"rgba(255,255,255,0.4)",display:"block",marginBottom:6 }}>{label}</label>
                <input type={type} value={form[key]} onChange={e=>setForm(f=>({ ...f,[key]:e.target.value }))} placeholder={placeholder} disabled={disabled}
                  style={{ width:"100%",padding:"10px 12px",borderRadius:8,border:"1px solid rgba(255,255,255,0.1)",background:disabled?"rgba(255,255,255,0.02)":"rgba(255,255,255,0.05)",color:disabled?"rgba(255,255,255,0.3)":"#fff",fontSize:13,outline:"none",boxSizing:"border-box" }} />
              </div>
            ))}
            <div>
              <label style={{ fontSize:11,fontWeight:600,textTransform:"uppercase",letterSpacing:"0.08em",color:"rgba(255,255,255,0.4)",display:"block",marginBottom:6 }}>Perfil</label>
              <select value={form.perfil} onChange={e=>setForm(f=>({ ...f,perfil:e.target.value }))}
                style={{ width:"100%",padding:"10px 12px",borderRadius:8,border:"1px solid rgba(255,255,255,0.1)",background:"#1a2235",color:"#fff",fontSize:13,outline:"none",boxSizing:"border-box" }}>
                <option value="viewer">Visualizador — só visualiza</option>
                <option value="admin">Admin — acesso total</option>
              </select>
            </div>
          </div>
          {formErro&&<div style={{ marginBottom:14,padding:"8px 12px",borderRadius:8,background:"#ef444420",border:"1px solid #ef444440",color:"#f87171",fontSize:12 }}>⚠️ {formErro}</div>}
          <div style={{ display:"flex",gap:10 }}>
            <LoadingBtn onClick={salvar} loading={salvando}>{editId?"Salvar alterações":"Criar usuário"}</LoadingBtn>
            <button onClick={()=>{ setShowForm(false); setEditId(null); setFormErro(""); }} style={{ padding:"9px 20px",borderRadius:8,border:"1px solid rgba(255,255,255,0.1)",background:"transparent",color:"rgba(255,255,255,0.4)",fontSize:13,cursor:"pointer" }}>Cancelar</button>
          </div>
        </div>
      )}
      <div style={{ borderRadius:16,border:"1px solid rgba(255,255,255,0.08)",background:"rgba(255,255,255,0.04)",overflow:"hidden" }}>
        {loading?(
          <div style={{ padding:40,textAlign:"center",color:"rgba(255,255,255,0.3)" }}>Carregando…</div>
        ):(
          <table style={{ width:"100%",borderCollapse:"collapse",fontSize:13 }}>
            <thead>
              <tr style={{ borderBottom:"1px solid rgba(255,255,255,0.05)" }}>
                {["Usuário","Perfil","Criado em","Ações"].map(h=>(
                  <th key={h} style={{ padding:"12px 16px",textAlign:h==="Ações"?"center":"left",fontSize:10,fontWeight:700,letterSpacing:"0.1em",textTransform:"uppercase",color:"rgba(255,255,255,0.25)" }}>{h}</th>
                ))}
              </tr>
            </thead>
            <tbody>
              {usuarios.map(u=>{
                const pl=perfilStyle[u.perfil]||perfilStyle.viewer;
                const isSelf=u.id===usuarioAtual.id;
                return (
                  <tr key={u.id} style={{ borderBottom:"1px solid rgba(255,255,255,0.04)" }}>
                    <td style={{ padding:"14px 16px" }}>
                      <div style={{ display:"flex",alignItems:"center",gap:10 }}>
                        <div style={{ width:34,height:34,borderRadius:10,background:isSelf?"rgba(56,189,248,0.15)":"rgba(255,255,255,0.06)",display:"flex",alignItems:"center",justifyContent:"center",fontSize:14 }}>
                          {u.perfil==="admin"?"👑":"👤"}
                        </div>
                        <div>
                          <div style={{ fontWeight:600,color:"#fff" }}>{u.nome} {isSelf&&<span style={{ fontSize:10,color:"#38bdf8" }}>(você)</span>}</div>
                        </div>
                      </div>
                    </td>
                    <td style={{ padding:"14px 16px" }}>
                      <span style={{ display:"inline-flex",alignItems:"center",gap:5,borderRadius:999,border:`1px solid ${pl.border}`,background:pl.bg,color:pl.color,padding:"3px 10px",fontSize:11,fontWeight:700 }}>{pl.label}</span>
                    </td>
                    <td style={{ padding:"14px 16px",color:"rgba(255,255,255,0.35)",fontSize:12 }}>
                      {u.created_at?new Date(u.created_at).toLocaleDateString("pt-BR"):"—"}
                    </td>
                    <td style={{ padding:"14px 16px",textAlign:"center" }}>
                      <div style={{ display:"flex",gap:6,justifyContent:"center" }}>
                        <button onClick={()=>editar(u)} style={{ padding:"5px 12px",borderRadius:7,border:"1px solid rgba(255,255,255,0.1)",background:"rgba(255,255,255,0.05)",color:"rgba(255,255,255,0.6)",fontSize:12,cursor:"pointer" }}>✏️ Editar</button>
                        {!isSelf&&(
                          confirmarDel===u.id
                            ?<><button onClick={()=>excluir(u.id)} style={{ padding:"5px 12px",borderRadius:7,border:"none",background:"#ef4444",color:"#fff",fontSize:12,fontWeight:700,cursor:"pointer" }}>Confirmar</button>
                               <button onClick={()=>setConfirmarDel(null)} style={{ padding:"5px 12px",borderRadius:7,border:"1px solid rgba(255,255,255,0.1)",background:"transparent",color:"rgba(255,255,255,0.4)",fontSize:12,cursor:"pointer" }}>Cancelar</button></>
                            :<button onClick={()=>setConfirmarDel(u.id)} style={{ padding:"5px 12px",borderRadius:7,border:"1px solid rgba(239,68,68,0.3)",background:"rgba(239,68,68,0.08)",color:"#f87171",fontSize:12,cursor:"pointer" }}>🗑 Excluir</button>
                        )}
                      </div>
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        )}
      </div>
    </div>
  );
}

// ─── App Principal ────────────────────────────────────────────────────────────
function App() {
  const toasts = useToastSystem();
  const [usuario, setUsuario]           = useState(null);
  const [checkingAuth, setCheckingAuth] = useState(true);
  const [aba, setAba]                   = useState("dashboard");
  const [clients, setClients]           = useState([]);
  const [dispatches, setDispatches]     = useState([]);
  const [lastUpdated, setLastUpdated]   = useState("");
  const [loadingData, setLoadingData]   = useState(false);
  const [confirmLimparDesl, setConfirmLimparDesl] = useState(false);
  const [confirmLimparTudo, setConfirmLimparTudo] = useState(false);

  useEffect(()=>{
    supabaseClient.auth.getSession().then(async ({ data:{ session } })=>{
      if (session?.user) {
        // Carrega config e filiais do banco ANTES de mostrar o dashboard
        await carregarConfigBanco();

        let profile=null;
        for (let i=0;i<3;i++) {
          const { data:p } = await supabaseClient.from("profiles").select("*").eq("id",session.user.id).single();
          if (p) { profile=p; break; }
          await new Promise(r=>setTimeout(r,800));
        }
        const u={ ...session.user, nome:profile?.nome||session.user.email, perfil:profile?.perfil||"viewer" };
        setUsuario(u);
        await carregarDados();
      }
      setCheckingAuth(false);
    });
    const { data:{ subscription } } = supabaseClient.auth.onAuthStateChange(async (event,session)=>{
      if (event==="SIGNED_OUT") { setUsuario(null); setClients([]); setDispatches([]); }
    });
    return ()=>subscription.unsubscribe();
  },[]);

  async function fetchAll(table, order, ascending=true) {
    let all=[], from=0;
    const PAGE=1000;
    while (true) {
      const { data, error } = await supabaseClient.from(table).select("*").order(order,{ ascending }).range(from,from+PAGE-1);
      if (error) { console.error(`Erro ao buscar ${table}:`, error); break; }
      if (!data||data.length===0) break;
      all=all.concat(data);
      if (data.length<PAGE) break;
      from+=PAGE;
    }
    return all;
  }

  async function carregarDados() {
    setLoadingData(true);
    try {
      const [cls,dis] = await Promise.all([
        fetchAll("clients","nome_cliente",true),
        fetchAll("dispatches","data_hora",false),
      ]);
      const clsNorm=(cls||[]).map(c=>({ ...c,filial:limparEmpresa(c.filial) }));
      const disNorm=(dis||[]).map(d=>({ ...d, filial:limparEmpresa(d.filial), portaria_inteligente:d.portaria_inteligente||(d.nome_cliente||"").toUpperCase().includes("PORTARIA INTELIGENTE") }));
      setClients(clsNorm);
      setDispatches(disNorm);
      if (cls.length>0) setAba("dashboard");
    } catch(e) {
      toast("Erro ao carregar dados: " + (e.message||"verifique sua conexão"), "error");
    } finally {
      setLoadingData(false);
    }
  }

  async function handleLogin(user) {
    setUsuario(user);
    await carregarConfigBanco();
    await carregarDados();
  }
  async function handleLogout() { await supabaseClient.auth.signOut(); setUsuario(null); setClients([]); setDispatches([]); }

  async function handleImportClients(data) {
    setLoadingData(true);
    // Deduplicação por código + filial + nome (preserva contratos diferentes do mesmo cliente)
    const deduped = Object.values(
      data.reduce((acc, c) => {
        // Usa código + filial + primeiros 30 chars do nome como chave única
        const nomeKey = (c.nome_cliente||"").slice(0,30).replace(/\s+/g,"").toUpperCase();
        const key = `${c.codigo_cliente}||${c.filial}||${nomeKey}`;
        acc[key] = c;
        return acc;
      }, {})
    );
    let erros=0;
    for (let i=0;i<deduped.length;i+=500) {
      try {
        // Usa insert ao invés de upsert para preservar todos os contratos
        // Ignora conflito apenas se código+filial+nome_cliente for idêntico
        await supaQuery(()=>supabaseClient.from("clients").upsert(
          deduped.slice(i,i+500),
          { onConflict:"codigo_cliente,filial,nome_cliente", ignoreDuplicates:true }
        ));
      } catch(e) {
        // Fallback: tenta insert simples ignorando duplicatas exatas
        try {
          await supabaseClient.from("clients").insert(
            deduped.slice(i,i+500)
          ).select();
        } catch(e2) {
          erros++;
          console.error("Erro ao inserir lote:", e2);
        }
      }
    }
    if (erros>0) {
      toast(`⚠️ ${erros} lote(s) com erro ao salvar. Verifique o console.`, "warning");
    } else {
      toast(`✅ ${deduped.length} clientes importados com sucesso!`, "success");
    }
    setLastUpdated(new Date().toLocaleString("pt-BR"));
    await carregarDados();
    setAba("dashboard");
  }

  async function handleImportDispatches(data) {
    setLoadingData(true);
    try {
      const clientesExistentes=new Set(clients.map(c=>`${c.codigo_cliente}||${c.filial}`));
      const novosClientesMap={};
      for (const d of data) {
        if (!d.portaria_inteligente&&d.codigo_cliente&&d.filial) {
          const key=`${d.codigo_cliente}||${d.filial}`;
          if (!clientesExistentes.has(key)&&!novosClientesMap[key]) {
            novosClientesMap[key]={ codigo_cliente:d.codigo_cliente, nome_cliente:d.nome_cliente||d.codigo_cliente, filial:d.filial, mensalidade:0, status:"ativo" };
          }
        }
      }
      const novosClientes=Object.values(novosClientesMap);
      if (novosClientes.length>0) {
        for (let i=0;i<novosClientes.length;i+=500) {
          await supabaseClient.from("clients").upsert(novosClientes.slice(i,i+500),{ onConflict:"codigo_cliente,filial" });
        }
      }

      // Deduplicação
      const existentesSet=new Set();
      let fromDesl=0;
      while (true) {
        const { data:existentes } = await supabaseClient.from("dispatches").select("codigo_cliente,filial,data_hora,evento,viatura").range(fromDesl,fromDesl+999);
        if (!existentes||existentes.length===0) break;
        for (const e of existentes) existentesSet.add(`${e.codigo_cliente}||${e.filial}||${e.data_hora}||${e.evento}||${e.viatura}`);
        if (existentes.length<1000) break;
        fromDesl+=1000;
      }
      const novos=data.filter(d=>{ const chave=`${d.codigo_cliente||""}||${d.filial||""}||${d.data_hora||""}||${d.evento||""}||${d.viatura||""}`; return !existentesSet.has(chave); });
      const duplicados=data.length-novos.length;

      let totalInserido=0;
      for (let i=0;i<novos.length;i+=200) {
        const lote=novos.slice(i,i+200).map(d=>({ codigo_cliente:d.codigo_cliente||"", filial:d.filial||"", nome_cliente:d.nome_cliente||"", data_hora:d.data_hora||"", evento:d.evento||"", viatura:d.viatura||"", portaria_inteligente:d.portaria_inteligente||false }));
        try {
          await supaQuery(()=>supabaseClient.from("dispatches").insert(lote));
          totalInserido+=lote.length;
        } catch(e) {
          toast("Erro ao inserir lote: " + e.message, "error");
          setLoadingData(false);
          return;
        }
      }

      const msgNovos=novosClientes.length>0?` · ${novosClientes.length} clientes novos`:"";
      const msgDup=duplicados>0?` · ${duplicados} duplicados ignorados`:"";
      toast(`✅ ${totalInserido} deslocamentos adicionados!${msgNovos}${msgDup}`, "success", 6000);
      setLastUpdated(new Date().toLocaleString("pt-BR"));
      await carregarDados();
      setAba("dashboard");
    } catch(e) {
      toast("Erro ao importar: " + e.message, "error");
      setLoadingData(false);
    }
  }

  async function handleLimpar() {
    setLoadingData(true);
    try {
      let dIds=[],cIds=[],from=0;
      while (true) {
        const { data } = await supabaseClient.from("dispatches").select("id").range(from,from+999);
        if (!data||data.length===0) break;
        dIds=dIds.concat(data.map(r=>r.id));
        if (data.length<1000) break;
        from+=1000;
      }
      for (let i=0;i<dIds.length;i+=500) await supabaseClient.from("dispatches").delete().in("id",dIds.slice(i,i+500));
      from=0;
      while (true) {
        const { data } = await supabaseClient.from("clients").select("id").range(from,from+999);
        if (!data||data.length===0) break;
        cIds=cIds.concat(data.map(r=>r.id));
        if (data.length<1000) break;
        from+=1000;
      }
      for (let i=0;i<cIds.length;i+=500) await supabaseClient.from("clients").delete().in("id",cIds.slice(i,i+500));
      toast("Todos os dados foram apagados.", "success");
    } catch(e) {
      toast("Erro ao limpar dados: " + e.message, "error");
    }
    setClients([]); setDispatches([]); setLastUpdated(""); setAba("importacao");
    setLoadingData(false);
  }

  async function handleLimparDeslocamentos() {
    setLoadingData(true);
    try {
      let allIds=[], from=0;
      while (true) {
        const { data } = await supabaseClient.from("dispatches").select("id").range(from,from+999);
        if (!data||data.length===0) break;
        allIds=allIds.concat(data.map(r=>r.id));
        if (data.length<1000) break;
        from+=1000;
      }
      for (let i=0;i<allIds.length;i+=500) {
        await supaQuery(()=>supabaseClient.from("dispatches").delete().in("id",allIds.slice(i,i+500)));
      }
      toast(`✅ ${allIds.length} deslocamentos apagados com sucesso!`, "success");
      setDispatches([]);
      setConfirmLimparDesl(false);
    } catch(e) {
      toast("Erro ao apagar deslocamentos: " + e.message, "error");
    }
    setLoadingData(false);
  }

  if (checkingAuth) return (
    <div style={{ minHeight:"100vh",background:"#080c14",display:"flex",flexDirection:"column",alignItems:"center",justifyContent:"center",gap:16 }}>
      <style>{`@keyframes spin{to{transform:rotate(360deg)}}`}</style>
      <div style={{ width:36,height:36,borderRadius:"50%",border:"2px solid rgba(56,189,248,0.2)",borderTopColor:"#38bdf8",animation:"spin 0.8s linear infinite" }} />
      <div style={{ fontSize:13,color:"rgba(255,255,255,0.3)" }}>Verificando sessão…</div>
    </div>
  );

  if (!usuario) return <LoginScreen onLogin={handleLogin} />;

  const isAdmin = usuario.perfil==="admin";
  const piCount = dispatches.filter(d=>d.portaria_inteligente).length;

  return (
    <div className="dash-wrap" style={{ fontFamily:"'DM Sans','Segoe UI',sans-serif",minHeight:"100vh",background:"#080c14",padding:"28px 24px",color:"#fff" }}>
      <style>{`@keyframes spin{to{transform:rotate(360deg)}} @keyframes shimmer{0%{background-position:200% 0}100%{background-position:-200% 0}}`}</style>

      <ToastContainer toasts={toasts} />

      {loadingData&&(
        <div style={{ position:"fixed",inset:0,background:"rgba(0,0,0,0.6)",zIndex:2000,display:"flex",flexDirection:"column",alignItems:"center",justifyContent:"center",gap:16 }}>
          <div style={{ width:40,height:40,borderRadius:"50%",border:"3px solid rgba(56,189,248,0.2)",borderTopColor:"#38bdf8",animation:"spin 0.8s linear infinite" }} />
          <div style={{ fontSize:14,color:"rgba(255,255,255,0.5)" }}>Sincronizando…</div>
        </div>
      )}

      <div style={{ display:"flex",justifyContent:"space-between",alignItems:"flex-start",marginBottom:28 }}>
        <div>
          <div style={{ display:"flex",alignItems:"center",gap:8,marginBottom:6 }}>
            <div style={{ width:28,height:28,borderRadius:8,background:"rgba(56,189,248,0.15)",display:"flex",alignItems:"center",justifyContent:"center",fontSize:14 }}>🚔</div>
            <span style={{ fontSize:11,fontWeight:700,letterSpacing:"0.15em",textTransform:"uppercase",color:"#38bdf8" }}>Central de Monitoramento</span>
          </div>
          <h1 style={{ fontSize:26,fontWeight:800,margin:0,letterSpacing:"-0.5px" }}>Dashboard Executivo</h1>
          <p style={{ fontSize:13,color:"rgba(255,255,255,0.3)",margin:"4px 0 0" }}>Gestão e análise de deslocamentos de VTR</p>
        </div>
        <div style={{ display:"flex",alignItems:"center",gap:12,flexWrap:"wrap" }}>
          {lastUpdated&&(
            <div style={{ textAlign:"right" }}>
              <div style={{ fontSize:10,color:"rgba(255,255,255,0.2)",textTransform:"uppercase",letterSpacing:"0.08em" }}>Última importação</div>
              <div style={{ fontSize:12,color:"rgba(255,255,255,0.4)",fontWeight:600 }}>{lastUpdated}</div>
            </div>
          )}
          <div style={{ display:"flex",alignItems:"center",gap:8,padding:"8px 12px",borderRadius:10,background:"rgba(255,255,255,0.04)",border:"1px solid rgba(255,255,255,0.08)" }}>
            <div style={{ width:28,height:28,borderRadius:8,background:isAdmin?"rgba(248,113,113,0.15)":"rgba(56,189,248,0.15)",display:"flex",alignItems:"center",justifyContent:"center",fontSize:13 }}>{isAdmin?"👑":"👤"}</div>
            <div>
              <div style={{ fontSize:12,fontWeight:600,color:"#fff" }}>{usuario.nome}</div>
              <div style={{ fontSize:10,color:isAdmin?"#f87171":"#38bdf8" }}>{isAdmin?"Admin":"Visualizador"}</div>
            </div>
            <button onClick={handleLogout} title="Sair" style={{ marginLeft:4,width:26,height:26,borderRadius:7,border:"1px solid rgba(255,255,255,0.1)",background:"rgba(255,255,255,0.05)",color:"rgba(255,255,255,0.4)",fontSize:12,cursor:"pointer" }}>↩</button>
          </div>
          {isAdmin&&dispatches.length>0&&(
            confirmLimparDesl?(
              <div style={{ display:"flex",alignItems:"center",gap:6,padding:"6px 10px",borderRadius:10,background:"rgba(239,68,68,0.12)",border:"1px solid rgba(239,68,68,0.35)" }}>
                <span style={{ fontSize:11,color:"#f87171" }}>Apagar {dispatches.length} desl.?</span>
                <button onClick={handleLimparDeslocamentos} style={{ border:"none",background:"#ef4444",color:"#fff",borderRadius:7,padding:"4px 10px",cursor:"pointer",fontSize:11,fontWeight:700 }}>Confirmar</button>
                <button onClick={()=>setConfirmLimparDesl(false)} style={{ border:"1px solid rgba(255,255,255,0.15)",background:"transparent",color:"rgba(255,255,255,0.4)",borderRadius:7,padding:"4px 10px",cursor:"pointer",fontSize:11 }}>Cancelar</button>
              </div>
            ):(
              <button onClick={()=>setConfirmLimparDesl(true)} style={{ border:"1px solid rgba(251,146,60,0.35)",background:"rgba(251,146,60,0.08)",borderRadius:10,padding:"7px 12px",fontSize:12,color:"rgba(251,146,60,0.8)",cursor:"pointer" }}>🗑 Limpar deslocamentos</button>
            )
          )}
          {isAdmin&&(clients.length>0||dispatches.length>0)&&(
            confirmLimparTudo?(
              <div style={{ display:"flex",alignItems:"center",gap:6,padding:"8px 12px",borderRadius:10,background:"rgba(239,68,68,0.15)",border:"1px solid rgba(239,68,68,0.4)" }}>
                <div style={{ fontSize:11,color:"#f87171",lineHeight:1.4 }}>
                  <div style={{ fontWeight:700 }}>⚠️ Apagar TUDO?</div>
                  <div style={{ opacity:0.8 }}>{clients.length} clientes + {dispatches.length} deslocamentos</div>
                </div>
                <div style={{ display:"flex",flexDirection:"column",gap:4 }}>
                  <button onClick={()=>{ handleLimpar(); setConfirmLimparTudo(false); }} style={{ border:"none",background:"#ef4444",color:"#fff",borderRadius:7,padding:"5px 12px",cursor:"pointer",fontSize:11,fontWeight:700,whiteSpace:"nowrap" }}>Sim, apagar tudo</button>
                  <button onClick={()=>setConfirmLimparTudo(false)} style={{ border:"1px solid rgba(255,255,255,0.15)",background:"transparent",color:"rgba(255,255,255,0.4)",borderRadius:7,padding:"4px 12px",cursor:"pointer",fontSize:11 }}>Cancelar</button>
                </div>
              </div>
            ):(
              <button onClick={()=>setConfirmLimparTudo(true)} style={{ border:"1px solid rgba(239,68,68,0.3)",background:"rgba(239,68,68,0.08)",borderRadius:10,padding:"7px 12px",fontSize:12,color:"rgba(239,68,68,0.7)",cursor:"pointer" }}>🗑 Limpar tudo</button>
            )
          )}
        </div>
      </div>

      <div style={{ display:"flex",gap:8,marginBottom:24,flexWrap:"wrap" }}>
        <TabBtn active={aba==="dashboard"}    onClick={()=>setAba("dashboard")}>📊 Dashboard</TabBtn>
        <TabBtn active={aba==="portaria"}     onClick={()=>setAba("portaria")} accent="#a78bfa">
          🏢 Portaria Inteligente
          {piCount>0&&<span style={{ marginLeft:6,background:"rgba(167,139,250,0.2)",color:"#a78bfa",borderRadius:999,padding:"1px 7px",fontSize:10 }}>{piCount}</span>}
        </TabBtn>
        <TabBtn active={aba==="comparativos"} onClick={()=>setAba("comparativos")} accent="#34d399">📅 Comparativos</TabBtn>
        <TabBtn active={aba==="clientes"}     onClick={()=>setAba("clientes")} accent="#34d399">
          👥 Clientes
          {clients.length>0&&<span style={{ marginLeft:6,background:"rgba(52,211,153,0.2)",color:"#34d399",borderRadius:999,padding:"1px 7px",fontSize:10 }}>{clients.length}</span>}
        </TabBtn>
        <TabBtn active={aba==="relatorios"}   onClick={()=>setAba("relatorios")} accent="#fb923c">📋 Relatórios</TabBtn>
        {isAdmin&&<TabBtn active={aba==="importacao"} onClick={()=>setAba("importacao")}>📥 Importação</TabBtn>}
        {isAdmin&&<TabBtn active={aba==="config"}      onClick={()=>setAba("config")} accent="#34d399">⚙️ Configurações</TabBtn>}
        {isAdmin&&<TabBtn active={aba==="usuarios"}   onClick={()=>setAba("usuarios")} accent="#f87171">👑 Usuários</TabBtn>}
      </div>

      {aba==="dashboard"    && <DashboardTab clients={clients} dispatches={dispatches} />}
      {aba==="clientes"     && <ClientesTab clients={clients} dispatches={dispatches} supabaseClient={supabaseClient} onRefresh={carregarDados} isAdmin={isAdmin} />}
      {aba==="relatorios"   && <RelatoriosTab clients={clients} dispatches={dispatches} />}
      {aba==="portaria"     && <PortariaTab dispatches={dispatches} clients={clients} supabaseClient={supabaseClient} />}
      {aba==="comparativos" && <ComparativosTab dispatches={dispatches} />}
      {aba==="importacao"   && isAdmin && <ImportTab onImportClients={handleImportClients} onImportDispatches={handleImportDispatches} clients={clients} dispatches={dispatches} supabaseClient={supabaseClient} onRefresh={carregarDados} />}
      {aba==="config"       && isAdmin && <ConfigTab onRefresh={carregarDados} />}
      {aba==="usuarios"     && isAdmin && <UsuariosTab usuarioAtual={usuario} />}

      <div style={{ marginTop:24,textAlign:"center",fontSize:11,color:"rgba(255,255,255,0.15)" }}>
        Custo por deslocamento: R$ {CUSTO_FISCAL} · Dados em nuvem · Portaria Inteligente separada automaticamente
      </div>
    </div>
  );
}

const root = ReactDOM.createRoot(document.getElementById('root'));
root.render(React.createElement(App));
</script>
</body>
</html>
