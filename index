        <div style={{ display:"flex",gap:10,flexWrap:"wrap",alignItems:"center" }}>
          <select value={filialFiltro} onChange={e=>setFilialFiltro(e.target.value)} style={selStyle}>
            {filiais.map(f=><option key={f} value={f}>{f}</option>)}
          </select>
          <div style={{ display:"flex",gap:6 }}>
            {[["normal","🚗 Normal"],["pi","🏢 Port. Int."],["ambos","🔀 Ambos"]].map(([v,l]) => (
