      <div style={{ display:"flex",gap:6,marginBottom:24,borderBottom:"1px solid rgba(255,255,255,0.07)",paddingBottom:16 }}>
        <button onClick={()=>setSubAba("semanas")} style={{ padding:"8px 20px",borderRadius:10,fontSize:13,fontWeight:600,cursor:"pointer",border:subAba==="semanas"?"1px solid #38bdf8":"1px solid rgba(255,255,255,0.08)",background:subAba==="semanas"?"rgba(56,189,248,0.12)":"rgba(255,255,255,0.03)",color:subAba==="semanas"?"#38bdf8":"rgba(255,255,255,0.4)",transition:"all 0.15s" }}>
          🗓 Semanas
        </button>
        <button onClick={()=>setSubAba("meses")} style={{ padding:"8px 20px",borderRadius:10,fontSize:13,fontWeight:600,cursor:"pointer",border:subAba==="meses"?"1px solid #fb923c":"1px solid rgba(255,255,255,0.08)",background:subAba==="meses"?"rgba(251,146,60,0.12)":"rgba(255,255,255,0.03)",color:subAba==="meses"?"#fb923c":"rgba(255,255,255,0.4)",transition:"all 0.15s" }}>
          📆 Meses
        </button>
      </div>
      {subAba==="semanas" && <ComparativosSemanas dispatches={dispatches} filiais={filiais} dispatchesFiltrados={dispatchesFiltrados} tipoVisao={tipoVisao} />}
      {subAba==="meses"   && <ComparativosMeses   dispatches={dispatches} dispatchesFiltrados={dispatchesFiltrados} tipoVisao={tipoVisao} />}
    </div>
  );
}

// ─── Modal Detalhes do Cliente ────────────────────────────────────────────────
function ClienteModal({ cliente, dispatches, onClose, supabaseClient, isPortaria }) {
  if (!cliente) return null;
  const [obs, setObs] = useState("");
  const [salvandoObs, setSalvandoObs] = useState(false);
  const [obsCarregando, setObsCarregando] = useState(true);

  const meusDeslocs = dispatches.filter(
    d=>d.codigo_cliente===cliente.codigo_cliente&&d.filial===cliente.filial&&
    (isPortaria?d.portaria_inteligente:!d.portaria_inteligente)
  );

  useEffect(() => {
    if (!supabaseClient) { setObsCarregando(false); return; }
    async function loadObs() {
      setObsCarregando(true);
      try {
        const { data } = await supaQuery(() =>
          supabaseClient.from("clients").select("observacao")
            .eq("codigo_cliente",cliente.codigo_cliente)
            .eq("filial",cliente.filial).single()
        );
        if (data) setObs(data.observacao||"");
      } catch(e) {
        toast("Erro ao carregar observação", "error");
      } finally {
        setObsCarregando(false);
      }
    }
    loadObs();
  }, [cliente.codigo_cliente,cliente.filial]);

  async function salvarObs() {
    if (!supabaseClient) return;
    setSalvandoObs(true);
    try {
      await supaQuery(() =>
        supabaseClient.from("clients").update({ observacao:obs })
          .eq("codigo_cliente",cliente.codigo_cliente)
          .eq("filial",cliente.filial)
      );
      toast("Observação salva com sucesso!", "success");
    } catch(e) {
      toast("Erro ao salvar: " + (e.message||"tente novamente"), "error");
    } finally {
      setSalvandoObs(false);
    }
  }

  const eventoMap = {};
  for (const d of meusDeslocs) eventoMap[d.evento]=(eventoMap[d.evento]||0)+1;
  const eventos = Object.entries(eventoMap).sort((a,b)=>b[1]-a[1]);
  const totalEvt = meusDeslocs.length;
  const custo    = totalEvt*CUSTO_FISCAL;
  const mens     = cliente.mensalidade||0;

  const mesesSet = new Set();
  for (const d of meusDeslocs) {
    const dt = parseDataHora(d.data_hora);
    if (dt) { const mk=getMonthKey(dt); if (mk) mesesSet.add(mk); }
  }
  const mesesComDesl   = Array.from(mesesSet).sort();
  const qtdMeses       = mesesComDesl.length||1;
  const mensAcumulada  = mens*qtdMeses;
  const saldoAcumulado = mensAcumulada-custo;
  const sc = STATUS_CONFIG[cliente.status_financeiro||calcStatus(mens,custo/qtdMeses)]||STATUS_CONFIG["SEM DADOS"];

  return (
    <div style={{ position:"fixed",inset:0,background:"rgba(0,0,0,0.75)",zIndex:2000,display:"flex",alignItems:"center",justifyContent:"center",padding:16 }} onClick={onClose}>
      <div style={{ background:"#0f172a",border:"1px solid rgba(255,255,255,0.1)",borderRadius:20,width:"100%",maxWidth:720,maxHeight:"90vh",overflowY:"auto",padding:28 }} onClick={e=>e.stopPropagation()}>
        <div style={{ display:"flex",justifyContent:"space-between",alignItems:"flex-start",marginBottom:20 }}>
          <div>
            <div style={{ fontSize:18,fontWeight:700,color:"#fff",marginBottom:4 }}>{cliente.nome_cliente}</div>
            <div style={{ fontSize:12,color:"rgba(255,255,255,0.4)" }}>Cód. {cliente.codigo_cliente} · {cliente.filial}</div>
          </div>
          <div style={{ display:"flex",alignItems:"center",gap:10 }}>
            <span style={{ fontSize:11,fontWeight:700,padding:"4px 12px",borderRadius:99,background:sc.bg,color:sc.text }}>{cliente.status_financeiro||calcStatus(mens,custo/qtdMeses)}</span>
            <button onClick={onClose} style={{ background:"rgba(255,255,255,0.08)",border:"none",color:"#fff",borderRadius:8,padding:"6px 14px",cursor:"pointer",fontSize:13 }}>✕</button>
          </div>
        </div>
        <div style={{ display:"grid",gridTemplateColumns:"repeat(3,1fr)",gap:12,marginBottom:12 }}>
          {[
            { label:"Deslocamentos", val:totalEvt, color:"#38bdf8", sub:qtdMeses>1?`em ${qtdMeses} meses`:"no período" },
            { label:"Custo Operacional", val:`R$ ${custo.toLocaleString("pt-BR")}`, color:"#f472b6", sub:`R$ ${(custo/qtdMeses).toLocaleString("pt-BR",{maximumFractionDigits:0})}/mês` },
            { label:"Mensalidade/mês", val:mens>0?`R$ ${mens.toLocaleString("pt-BR",{minimumFractionDigits:2})}`:"—", color:"#34d399", sub:mens>0?`× ${qtdMeses} ${qtdMeses===1?"mês":"meses"}`:"sem cadastro" },
          ].map((k,i) => (
            <div key={i} style={{ background:"rgba(255,255,255,0.04)",borderRadius:12,padding:"14px 16px",textAlign:"center" }}>
              <div style={{ fontSize:20,fontWeight:800,color:k.color }}>{k.val}</div>
              <div style={{ fontSize:11,color:"rgba(255,255,255,0.4)",marginTop:4 }}>{k.label}</div>
              {k.sub&&<div style={{ fontSize:10,color:"rgba(255,255,255,0.25)",marginTop:2 }}>{k.sub}</div>}
            </div>
          ))}
        </div>
        {mens>0&&mesesComDesl.length>0&&(
          <div style={{ marginBottom:20,borderRadius:12,border:"1px solid rgba(255,255,255,0.08)",background:"rgba(255,255,255,0.02)",overflow:"hidden" }}>
            <div style={{ padding:"10px 16px",borderBottom:"1px solid rgba(255,255,255,0.06)",display:"flex",justifyContent:"space-between",alignItems:"center" }}>
              <span style={{ fontSize:10,fontWeight:700,letterSpacing:"0.12em",textTransform:"uppercase",color:"rgba(255,255,255,0.35)" }}>
                Resultado Acumulado — {qtdMeses} {qtdMeses===1?"mês":"meses"}
              </span>
              <div style={{ display:"flex",gap:6,flexWrap:"wrap" }}>
                {mesesComDesl.map(mk=>(
                  <span key={mk} style={{ fontSize:10,padding:"2px 8px",borderRadius:99,background:"rgba(56,189,248,0.1)",border:"1px solid rgba(56,189,248,0.2)",color:"#38bdf8",fontWeight:600 }}>{monthLabel(mk)}</span>
                ))}
              </div>
            </div>
            <div style={{ display:"grid",gridTemplateColumns:"1fr 1fr 1fr",gap:0 }}>
              {[
                { label:"Mensalidade acumulada", val:formatCurrency(mensAcumulada), color:"#34d399" },
                { label:"Custo acumulado", val:formatCurrency(custo), color:"#f472b6" },
                { label:"Saldo acumulado", val:formatCurrency(saldoAcumulado), color:saldoAcumulado>=0?"#34d399":"#f87171" },
              ].map((k,i)=>(
                <div key={i} style={{ padding:"12px 16px",textAlign:"center",borderRight:i<2?"1px solid rgba(255,255,255,0.06)":"none" }}>
                  <div style={{ fontSize:16,fontWeight:800,color:k.color }}>{k.val}</div>
                  <div style={{ fontSize:10,color:"rgba(255,255,255,0.35)",marginTop:3 }}>{k.label}</div>
                </div>
              ))}
            </div>
          </div>
        )}
        {eventos.length>0&&(
          <div style={{ marginBottom:20 }}>
            <div style={{ fontSize:11,fontWeight:700,color:"rgba(255,255,255,0.4)",letterSpacing:1,marginBottom:12 }}>MOTIVOS DOS DESLOCAMENTOS</div>
            <div style={{ display:"flex",flexDirection:"column",gap:8 }}>
              {eventos.map(([evt,cnt],i)=>{
                const pct=totalEvt>0?Math.round((cnt/totalEvt)*100):0;
                return (
                  <div key={i}>
                    <div style={{ display:"flex",justifyContent:"space-between",marginBottom:4 }}>
                      <span style={{ fontSize:12,color:"rgba(255,255,255,0.75)" }}>{evt}</span>
                      <span style={{ fontSize:12,fontWeight:700,color:CHART_COLORS[i%CHART_COLORS.length] }}>{cnt}x · {pct}%</span>
                    </div>
                    <div style={{ height:5,borderRadius:999,background:"rgba(255,255,255,0.06)" }}>
                      <div style={{ height:"100%",width:`${pct}%`,borderRadius:999,background:CHART_COLORS[i%CHART_COLORS.length] }} />
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        )}
        {supabaseClient&&(
          <div style={{ marginBottom:20 }}>
            <div style={{ fontSize:11,fontWeight:700,color:"rgba(255,255,255,0.4)",letterSpacing:1,marginBottom:8 }}>OBSERVAÇÃO / ACOMPANHAMENTO</div>
            {obsCarregando ? <Skeleton height={90} radius={10} /> : (
              <textarea value={obs} onChange={e=>setObs(e.target.value)}
                placeholder="Ex: Manutenção aberta em 03/2026, sensor com planta na frente..."
                style={{ width:"100%",minHeight:90,background:"rgba(255,255,255,0.05)",border:"1px solid rgba(255,255,255,0.1)",borderRadius:10,padding:"10px 14px",color:"#fff",fontSize:13,resize:"vertical",outline:"none",fontFamily:"inherit" }} />
            )}
            <div style={{ display:"flex",justifyContent:"flex-end",marginTop:8 }}>
              <LoadingBtn onClick={salvarObs} loading={salvandoObs}>
                Salvar Observação
              </LoadingBtn>
            </div>
          </div>
        )}
        {meusDeslocs.length>0&&(
          <div>
            {/* Gráfico de tendência */}
            <div style={{ marginBottom:20, padding:"14px 16px", borderRadius:12, border:"1px solid rgba(255,255,255,0.08)", background:"rgba(255,255,255,0.02)" }}>
              <TendenciaClienteChart cliente={cliente} dispatches={dispatches} />
            </div>
            <div style={{ fontSize:11,fontWeight:700,color:"rgba(255,255,255,0.4)",letterSpacing:1,marginBottom:12 }}>HISTÓRICO DE DESLOCAMENTOS ({meusDeslocs.length})</div>
            <div style={{ display:"flex",flexDirection:"column",gap:6,maxHeight:200,overflowY:"auto" }}>
              {meusDeslocs.map((d,i)=>(
                <div key={i} style={{ display:"flex",justifyContent:"space-between",padding:"8px 12px",background:"rgba(255,255,255,0.03)",borderRadius:8,fontSize:12 }}>
                  <span style={{ color:"rgba(255,255,255,0.7)" }}>{d.evento}</span>
                  <div style={{ display:"flex",gap:16,color:"rgba(255,255,255,0.35)" }}>
                    <span>{d.viatura}</span><span>{d.data_hora}</span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>
  );
}

// ─── C: Alertas Automáticos ──────────────────────────────────────────────────
function AlertasPanel({ clients, dispatches, limiteDeslocamentos = 10 }) {
  const [aberto, setAberto] = useState(false);
  const [limite, setLimite] = useState(limiteDeslocamentos);

  const alertas = useMemo(() => {
    const mesAtual = getMonthKey(new Date());
    const dispMap = {};
    for (const d of dispatches.filter(x => !x.portaria_inteligente)) {
      const dt = parseDataHora(d.data_hora);
      if (!dt || getMonthKey(dt) !== mesAtual) continue;
      const k = `${d.codigo_cliente}||${d.filial}`;
      dispMap[k] = (dispMap[k] || 0) + 1;
    }

    const lista = [];
    for (const c of clients) {
      const key  = `${c.codigo_cliente}||${c.filial}`;
      const desl = dispMap[key] || 0;
      const custo = desl * CUSTO_FISCAL;
      const mens  = parseFloat(c.mensalidade) || 0;
      const saldo = mens - custo;

      // Alerta 1: muitos deslocamentos no mês
      if (desl >= limite) {
        lista.push({ tipo: "volume", cor: "#f87171", icone: "🚨", titulo: "Alto volume", sub: `${desl} desl. em ${monthLabel(mesAtual)}`, cliente: c.nome_cliente, codigo: c.codigo_cliente, filial: c.filial, desl, mens, saldo });
      }
      // Alerta 2: prejuízo com mensalidade cadastrada
      else if (mens > 0 && saldo < 0) {
        lista.push({ tipo: "prejuizo", cor: "#f87171", icone: "❌", titulo: "Prejuízo no mês", sub: `${formatCurrency(saldo)} · ${desl} desl.`, cliente: c.nome_cliente, codigo: c.codigo_cliente, filial: c.filial, desl, mens, saldo });
      }
      // Alerta 3: risco (margem < 30%)
      else if (mens > 0 && saldo >= 0 && saldo < mens * 0.3) {
        lista.push({ tipo: "risco", cor: "#fbbf24", icone: "⚠️", titulo: "Em risco", sub: `Margem ${Math.round((saldo/mens)*100)}% · ${desl} desl.`, cliente: c.nome_cliente, codigo: c.codigo_cliente, filial: c.filial, desl, mens, saldo });
      }
    }
    return lista.sort((a, b) => {
      const ordem = { volume: 0, prejuizo: 1, risco: 2 };
      return (ordem[a.tipo] ?? 3) - (ordem[b.tipo] ?? 3) || b.desl - a.desl;
    });
  }, [clients, dispatches, limite]);

  const criticos  = alertas.filter(a => a.tipo === "prejuizo" || a.tipo === "volume");
  const atencao   = alertas.filter(a => a.tipo === "risco");

  if (alertas.length === 0) return (
    <div style={{ marginBottom:20, padding:"12px 18px", borderRadius:14, border:"1px solid rgba(52,211,153,0.2)", background:"rgba(52,211,153,0.05)", display:"flex", alignItems:"center", gap:10 }}>
      <span style={{ fontSize:18 }}>✅</span>
      <div style={{ fontSize:13, color:"#34d399", fontWeight:600 }}>Nenhum alerta para {monthLabel(getMonthKey(new Date()))} — carteira saudável!</div>
    </div>
  );

  return (
    <div style={{ marginBottom:20 }}>
      {/* Header clicável */}
      <div onClick={() => setAberto(a => !a)}
        style={{ padding:"14px 18px", borderRadius: aberto ? "14px 14px 0 0" : 14, border:"1px solid rgba(248,113,113,0.3)", background:"rgba(248,113,113,0.08)", display:"flex", alignItems:"center", justifyContent:"space-between", cursor:"pointer", transition:"all 0.15s" }}>
        <div style={{ display:"flex", alignItems:"center", gap:12 }}>
          <span style={{ fontSize:20 }}>🚨</span>
          <div>
            <div style={{ fontSize:13, fontWeight:700, color:"#f87171" }}>
              {criticos.length > 0 ? `${criticos.length} alerta${criticos.length > 1 ? "s" : ""} crítico${criticos.length > 1 ? "s" : ""}` : ""}
              {criticos.length > 0 && atencao.length > 0 ? " · " : ""}
              {atencao.length > 0 ? <span style={{ color:"#fbbf24" }}>{atencao.length} em atenção</span> : ""}
            </div>
            <div style={{ fontSize:11, color:"rgba(255,255,255,0.35)", marginTop:2 }}>
              Mês atual: {monthLabel(getMonthKey(new Date()))} · clique para {aberto ? "fechar" : "ver detalhes"}
            </div>
          </div>
        </div>
        <div style={{ display:"flex", alignItems:"center", gap:12 }}>
          {/* Limite configurável */}
          <div onClick={e => e.stopPropagation()} style={{ display:"flex", alignItems:"center", gap:6, fontSize:11, color:"rgba(255,255,255,0.4)" }}>
            <span>Limite:</span>
            <input type="number" min="1" value={limite} onChange={e => setLimite(parseInt(e.target.value)||1)}
              style={{ width:52, padding:"3px 6px", borderRadius:6, border:"1px solid rgba(255,255,255,0.15)", background:"rgba(255,255,255,0.07)", color:"#fff", fontSize:12, outline:"none", textAlign:"center" }} />
            <span>desl./mês</span>
          </div>
          <span style={{ fontSize:18, color:"rgba(255,255,255,0.4)", transition:"transform 0.2s", transform: aberto ? "rotate(180deg)" : "rotate(0deg)" }}>▾</span>
        </div>
      </div>

      {/* Lista de alertas */}
      {aberto && (
        <div style={{ border:"1px solid rgba(248,113,113,0.2)", borderTop:"none", borderRadius:"0 0 14px 14px", background:"rgba(15,23,42,0.95)", overflow:"hidden" }}>
          {alertas.map((a, i) => (
            <div key={i} style={{ display:"flex", alignItems:"center", gap:14, padding:"12px 18px", borderBottom: i < alertas.length - 1 ? "1px solid rgba(255,255,255,0.05)" : "none", transition:"background 0.15s" }}
              onMouseEnter={e => e.currentTarget.style.background="rgba(255,255,255,0.03)"}
              onMouseLeave={e => e.currentTarget.style.background="transparent"}>
              <span style={{ fontSize:18, flexShrink:0 }}>{a.icone}</span>
              <div style={{ flex:1, minWidth:0 }}>
                <div style={{ display:"flex", alignItems:"center", gap:8, flexWrap:"wrap" }}>
                  <span style={{ fontSize:12, fontWeight:700, color:a.cor }}>{a.titulo}</span>
                  <span style={{ fontSize:10, padding:"2px 8px", borderRadius:99, background:`${a.cor}18`, border:`1px solid ${a.cor}30`, color:a.cor }}>{a.filial}</span>
                </div>
                <div style={{ fontSize:13, fontWeight:600, color:"#fff", marginTop:2, whiteSpace:"nowrap", overflow:"hidden", textOverflow:"ellipsis" }}>{a.cliente}</div>
                <div style={{ fontSize:11, color:"rgba(255,255,255,0.35)", marginTop:1, fontFamily:"monospace" }}>{a.codigo}</div>
              </div>
              <div style={{ textAlign:"right", flexShrink:0 }}>
                <div style={{ fontSize:13, fontWeight:700, color:a.cor }}>{a.sub}</div>
                {a.mens > 0 && <div style={{ fontSize:11, color:"rgba(255,255,255,0.3)", marginTop:2 }}>Mens: {formatCurrency(a.mens)}</div>}
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  );
}

// ─── D: Gráfico de Tendência Individual ──────────────────────────────────────
function TendenciaClienteChart({ cliente, dispatches }) {
  const data = useMemo(() => {
    const meses = {};
    for (const d of dispatches.filter(x =>
      x.codigo_cliente === cliente.codigo_cliente &&
      x.filial === cliente.filial &&
      !x.portaria_inteligente
    )) {
      const dt = parseDataHora(d.data_hora);
      if (!dt) continue;
      const mk = getMonthKey(dt);
      if (mk) meses[mk] = (meses[mk] || 0) + 1;
    }
    return Object.entries(meses)
      .sort(([a], [b]) => a.localeCompare(b))
      .slice(-6)
      .map(([mk, total]) => ({ label: monthLabel(mk), value: total }));
  }, [cliente, dispatches]);

  if (data.length < 2) return (
    <div style={{ textAlign:"center", padding:"20px 0", color:"rgba(255,255,255,0.25)", fontSize:12 }}>
      Dados insuficientes para tendência (mín. 2 meses)
    </div>
  );

  // Calcula tendência (subindo/descendo)
  const ultimo    = data[data.length - 1]?.value || 0;
  const penultimo = data[data.length - 2]?.value || 0;
  const tendencia = ultimo > penultimo ? "subindo" : ultimo < penultimo ? "caindo" : "estável";
  const tCor      = tendencia === "subindo" ? "#f87171" : tendencia === "caindo" ? "#34d399" : "#38bdf8";
  const tIcon     = tendencia === "subindo" ? "📈" : tendencia === "caindo" ? "📉" : "➡️";

  return (
    <div>
      <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", marginBottom:12 }}>
        <div style={{ fontSize:11, fontWeight:700, color:"rgba(255,255,255,0.4)", letterSpacing:1, textTransform:"uppercase" }}>
          Tendência — Últimos {data.length} meses
        </div>
        <div style={{ fontSize:12, fontWeight:700, color:tCor, display:"flex", alignItems:"center", gap:5 }}>
          {tIcon} {tendencia.charAt(0).toUpperCase() + tendencia.slice(1)}
        </div>
      </div>
      <LineChart data={data} label="Deslocamentos" color="#38bdf8" height={140} />
    </div>
  );
}

function MesesResumo({ dispatches, filialFiltro, cidadeFiltro, codigosFiltrados, tipo, clients }) {
  const isPi = tipo==="pi";
  const accent = isPi?"#a78bfa":"#38bdf8";

  const mesesData = useMemo(() => {
    const base = dispatches.filter(d => {
      if (isPi?!d.portaria_inteligente:d.portaria_inteligente) return false;
      if (filialFiltro&&filialFiltro!=="Todas"&&d.filial!==filialFiltro) return false;
      if (codigosFiltrados&&!codigosFiltrados.has(`${d.codigo_cliente}||${d.filial}`)) return false;
      return true;
    });
    const mesMap = {};
    for (const d of base) {
      const dt = parseDataHora(d.data_hora);
      if (!dt) continue;
      const mk = getMonthKey(dt);
      if (!mk) continue;
      if (!mesMap[mk]) mesMap[mk]={ total:0, clientes:new Set(), custo:0 };
      mesMap[mk].total++;
      mesMap[mk].clientes.add(`${d.codigo_cliente}||${d.filial}`);
      mesMap[mk].custo+=CUSTO_FISCAL;
    }
    const clienteMensMap = {};
    if (clients) {
      for (const c of clients) {
        if (c.mensalidade>0) clienteMensMap[`${c.codigo_cliente}||${c.filial}`]=parseFloat(c.mensalidade)||0;
      }
    }
    return Object.entries(mesMap).map(([mk,v]) => {
      const mensTotal = Array.from(v.clientes).reduce((s,k)=>s+(clienteMensMap[k]||0),0);
      return { mk, label:monthLabel(mk), total:v.total, clientes:v.clientes.size, custo:v.custo, mensTotal, saldo:mensTotal-v.custo };
    }).sort((a,b)=>a.mk.localeCompare(b.mk));
  }, [dispatches,filialFiltro,tipo,clients]);

  if (mesesData.length===0) return null;
  const maxTotal = Math.max(...mesesData.map(m=>m.total));
  const totalGeral = mesesData.reduce((s,m)=>s+m.total,0);
  const temMens = mesesData.some(m=>m.mensTotal>0);

  return (
    <Card style={{ marginBottom:28 }}>
      <div style={{ padding:"16px 20px",borderBottom:"1px solid rgba(255,255,255,0.07)",display:"flex",justifyContent:"space-between",alignItems:"center" }}>
        <div>
          <SectionLabel>{isPi?"🏢 Portaria Inteligente":"🚗 Deslocamentos Normais"} — Total por Mês</SectionLabel>
          <p style={{ fontSize:11,color:"rgba(255,255,255,0.25)",margin:"-8px 0 0" }}>
            {mesesData.length} {mesesData.length===1?"mês":"meses"} · {totalGeral.toLocaleString("pt-BR")} eventos
          </p>
        </div>
        <div style={{ textAlign:"right" }}>
          <div style={{ fontSize:22,fontWeight:800,color:accent }}>{totalGeral.toLocaleString("pt-BR")}</div>
          <div style={{ fontSize:10,color:"rgba(255,255,255,0.3)" }}>total geral</div>
        </div>
      </div>
      <div style={{ padding:"16px 20px" }}>
        <div style={{ display:"flex",alignItems:"flex-end",gap:8,height:100,marginBottom:16 }}>
          {mesesData.map((m,i) => {
            const pct = maxTotal>0?(m.total/maxTotal)*100:0;
            return (
              <div key={m.mk} style={{ flex:1,display:"flex",flexDirection:"column",alignItems:"center",gap:4,height:"100%" }}>
                <div style={{ fontSize:10,color:accent,fontWeight:700 }}>{m.total}</div>
                <div style={{ flex:1,width:"100%",display:"flex",alignItems:"flex-end" }}>
                  <div style={{ width:"100%",height:`${pct}%`,minHeight:4,borderRadius:"6px 6px 0 0",background:`linear-gradient(180deg,${accent}cc,${accent}66)`,transition:"height 0.4s" }} />
                </div>
                <div style={{ fontSize:9,color:"rgba(255,255,255,0.4)",textAlign:"center",lineHeight:1.2 }}>{m.label}</div>
              </div>
            );
          })}
        </div>
        <div style={{ overflowX:"auto" }}>
          <table style={{ width:"100%",borderCollapse:"collapse",fontSize:12 }}>
            <thead>
              <tr style={{ borderBottom:"1px solid rgba(255,255,255,0.07)" }}>
                {["Mês","Eventos","Clientes Ativos","Custo Op.",...(temMens?["Mensalidade","Saldo"]:[])].map(h=>(
                  <th key={h} style={{ padding:"8px 14px",textAlign:h==="Mês"?"left":"right",fontSize:10,fontWeight:700,letterSpacing:"0.1em",textTransform:"uppercase",color:"rgba(255,255,255,0.25)" }}>{h}</th>
                ))}
              </tr>
            </thead>
            <tbody>
              {mesesData.map((m,i)=>{
                const prev = mesesData[i-1];
                const trend = prev?(m.total>prev.total?"▲":m.total<prev.total?"▼":"─"):null;
                const trendColor = !trend?"transparent":m.total>(prev?.total||0)?"#f87171":m.total<(prev?.total||0)?"#34d399":"rgba(255,255,255,0.2)";
                return (
                  <tr key={m.mk} style={{ borderBottom:"1px solid rgba(255,255,255,0.04)" }}
                    onMouseEnter={e=>e.currentTarget.style.background=`${accent}08`}
                    onMouseLeave={e=>e.currentTarget.style.background="transparent"}>
                    <td style={{ padding:"10px 14px" }}>
                      <div style={{ display:"flex",alignItems:"center",gap:8 }}>
                        <div style={{ width:8,height:8,borderRadius:"50%",background:CHART_COLORS[i%CHART_COLORS.length],flexShrink:0 }} />
                        <span style={{ fontWeight:700,color:"#fff" }}>{m.label}</span>
                        {trend&&<span style={{ fontSize:9,color:trendColor }}>{trend}</span>}
                      </div>
                    </td>
                    <td style={{ padding:"10px 14px",textAlign:"right",fontWeight:800,color:accent,fontSize:14 }}>{m.total.toLocaleString("pt-BR")}</td>
                    <td style={{ padding:"10px 14px",textAlign:"right",color:"rgba(255,255,255,0.5)" }}>{m.clientes}</td>
                    <td style={{ padding:"10px 14px",textAlign:"right",color:"#fb923c",fontWeight:600 }}>{formatCurrency(m.custo)}</td>
                    {temMens&&<>
                      <td style={{ padding:"10px 14px",textAlign:"right",color:"#34d399" }}>{m.mensTotal>0?formatCurrency(m.mensTotal):<span style={{ color:"rgba(255,255,255,0.2)" }}>—</span>}</td>
                      <td style={{ padding:"10px 14px",textAlign:"right",fontWeight:700,color:m.mensTotal>0?(m.saldo>=0?"#34d399":"#f87171"):"rgba(255,255,255,0.2)" }}>{m.mensTotal>0?formatCurrency(m.saldo):"—"}</td>
                    </>}
                  </tr>
                );
              })}
              <tr style={{ borderTop:"2px solid rgba(255,255,255,0.1)",background:"rgba(255,255,255,0.03)" }}>
                <td style={{ padding:"10px 14px",fontWeight:700,color:"rgba(255,255,255,0.5)",fontSize:11,textTransform:"uppercase",letterSpacing:"0.08em" }}>Total</td>
                <td style={{ padding:"10px 14px",textAlign:"right",fontWeight:800,color:accent,fontSize:15 }}>{totalGeral.toLocaleString("pt-BR")}</td>
                <td style={{ padding:"10px 14px",textAlign:"right",color:"rgba(255,255,255,0.4)",fontWeight:600 }}>
                  {new Set(dispatches.filter(d=>(isPi?d.portaria_inteligente:!d.portaria_inteligente)&&(filialFiltro==="Todas"||d.filial===filialFiltro)).map(d=>`${d.codigo_cliente}||${d.filial}`)).size}
                </td>
                <td style={{ padding:"10px 14px",textAlign:"right",fontWeight:700,color:"#fb923c" }}>{formatCurrency(mesesData.reduce((s,m)=>s+m.custo,0))}</td>
                {temMens&&<>
                  <td style={{ padding:"10px 14px",textAlign:"right",fontWeight:700,color:"#34d399" }}>{formatCurrency(mesesData.reduce((s,m)=>s+m.mensTotal,0))}</td>
                  <td style={{ padding:"10px 14px",textAlign:"right",fontWeight:800,color:mesesData.reduce((s,m)=>s+m.saldo,0)>=0?"#34d399":"#f87171",fontSize:14 }}>{formatCurrency(mesesData.reduce((s,m)=>s+m.saldo,0))}</td>
                </>}
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </Card>
  );
}

// ─── Portaria Tab ─────────────────────────────────────────────────────────────
function PortariaTab({ dispatches, clients, supabaseClient }) {
  const [filialFiltro, setFilialFiltro] = useState("Todas");
  const [clienteSelecionado, setClienteSelecionado] = useState(null);

  const { ranking, porFilial, eventos, filiais, totalEventos } = useMemo(() => {
    const piDispatches = dispatches.filter(d=>d.portaria_inteligente);
    if (piDispatches.length===0) return { ranking:[],porFilial:[],eventos:[],filiais:["Todas"],totalEventos:0 };
    const clienteMap={}, filialMap={}, eventoMap={};
    const mensMap={};
    for (const c of clients) mensMap[`${c.codigo_cliente}||${c.filial}`]=parseFloat(c.mensalidade)||0;
    for (const d of piDispatches) {
      const key=`${d.codigo_cliente}||${d.filial}`;
      if (!clienteMap[key]) clienteMap[key]={ codigo_cliente:d.codigo_cliente, nome_cliente:d.nome_cliente||d.codigo_cliente, filial:d.filial, total_eventos:0 };
      clienteMap[key].total_eventos++;
      if (d.filial) filialMap[d.filial]=(filialMap[d.filial]||0)+1;
      if (d.evento) eventoMap[d.evento]=(eventoMap[d.evento]||0)+1;
    }
    const ranking = Object.values(clienteMap).map(c=>{
      const mens=mensMap[`${c.codigo_cliente}||${c.filial}`]||0;
      const custo=c.total_eventos*CUSTO_FISCAL;
      return { ...c, mensalidade:mens, custo_operacional:custo, saldo:mens-custo, status_financeiro:calcStatus(mens,custo) };
    }).sort((a,b)=>b.total_eventos-a.total_eventos);
    const filiais=["Todas",...new Set(piDispatches.map(d=>d.filial).filter(Boolean))];
    const porFilial=Object.entries(filialMap).map(([filial,total])=>({filial,total})).sort((a,b)=>b.total-a.total);
    const eventos=Object.entries(eventoMap).map(([evento,total])=>({evento,total})).sort((a,b)=>b.total-a.total).slice(0,7);
    return { ranking, porFilial, eventos, filiais, totalEventos:piDispatches.length };
  }, [dispatches,clients]);

  const rankingFiltrado = useMemo(()=>{
    const base = filialFiltro==="Todas"?ranking:ranking.filter(r=>r.filial===filialFiltro);
    return base.slice(0,10);
  }, [ranking,filialFiltro]);

  if (totalEventos===0) return <EmptyState icon="🏢" title="Nenhum evento de Portaria Inteligente" sub="Os eventos são detectados automaticamente na importação." />;

  return (
    <>
      {(()=>{
        const base=filialFiltro==="Todas"?ranking:ranking.filter(r=>r.filial===filialFiltro);
        const totalEvtFil=base.reduce((s,c)=>s+c.total_eventos,0);
        const totalMensPi=base.reduce((s,c)=>s+(c.mensalidade||0),0);
        const totalCustoPi=base.reduce((s,c)=>s+c.custo_operacional,0);
        const totalSaldoPi=base.reduce((s,c)=>s+(c.mensalidade?c.saldo:0),0);
        return (
          <>
            <div className="grid-4" style={{ marginBottom:12 }}>
              <KPICard label="Total de Eventos"  value={totalEvtFil}               sub="portaria inteligente"    icon="🏢" accent="#a78bfa" />
              <KPICard label="Clientes Ativos"   value={base.length}               sub="com eventos registrados" icon="👥" accent="#38bdf8" />
              <KPICard label="Mensalidade Total" value={formatCurrency(totalMensPi)} sub={`${base.filter(c=>c.mensalidade>0).length} clientes c/ mensalidade`} icon="💳" accent="#34d399" />
              <KPICard label="Saldo Total"       value={formatCurrency(totalSaldoPi)} sub="mensalidade − custo op." icon={totalSaldoPi>=0?"✅":"❌"} accent={totalSaldoPi>=0?"#34d399":"#f87171"} />
            </div>
            <div className="grid-4" style={{ marginBottom:28 }}>
              <KPICard label="Média por Cliente" value={(totalEvtFil/(base.length||1)).toFixed(1)} sub="eventos/cliente" icon="📊" accent="#34d399" />
              <KPICard label="Custo Operacional" value={formatCurrency(totalCustoPi)} sub={`@ R$ ${CUSTO_FISCAL}/evento`} icon="💰" accent="#fb923c" />
              <KPICard label="Em Prejuízo" value={base.filter(c=>c.status_financeiro==="PREJUÍZO").length} sub="com mensalidade" icon="🔴" accent="#f87171" />
              <KPICard label="Em Risco"    value={base.filter(c=>c.status_financeiro==="RISCO").length}    sub="com mensalidade" icon="🟡" accent="#fbbf24" />
            </div>
          </>
        );
      })()}
      <MesesResumo dispatches={dispatches} filialFiltro={filialFiltro} tipo="pi" clients={clients} />
      <div className="grid-2">
        <Card><div style={{ padding:20 }}><SectionLabel>Eventos por Filial</SectionLabel><BarChart data={porFilial.map(d=>({label:d.filial.slice(0,14),value:d.total}))} label="Eventos" height={220} /></div></Card>
        <Card><div style={{ padding:20 }}><SectionLabel>Eventos Mais Frequentes</SectionLabel><DonutChart data={eventos.map(d=>({label:d.evento.slice(0,24),value:d.total}))} height={220} /></div></Card>
      </div>
      <Card>
        <div style={{ borderBottom:"1px solid rgba(255,255,255,0.07)",padding:"16px 20px",display:"flex",justifyContent:"space-between",alignItems:"center",flexWrap:"wrap",gap:12 }}>
          <div>
            <SectionLabel>Top 10 — Portaria Inteligente</SectionLabel>
            <p style={{ fontSize:11,color:"rgba(255,255,255,0.25)",margin:"-8px 0 0" }}>Ordenado por quantidade de eventos</p>
          </div>
          <div style={{ display:"flex",gap:6,flexWrap:"wrap" }}>
            {filiais.map(f=><FilterBtn key={f} active={filialFiltro===f} onClick={()=>setFilialFiltro(f)}>{f}</FilterBtn>)}
          </div>
        </div>
        <div style={{ overflowX:"auto" }}>
          <table style={{ width:"100%",borderCollapse:"collapse",fontSize:13 }}>
            <thead>
              <tr style={{ borderBottom:"1px solid rgba(255,255,255,0.05)" }}>
                {["#","Cliente","Filial","Eventos","Mensalidade","Custo Op.","Saldo","Status"].map(h=>(
                  <th key={h} style={{ padding:"12px 16px",textAlign:["Eventos","Mensalidade","Custo Op.","Saldo"].includes(h)?"right":h==="Status"?"center":"left",fontSize:10,fontWeight:700,letterSpacing:"0.1em",textTransform:"uppercase",color:"rgba(255,255,255,0.25)" }}>{h}</th>
                ))}
              </tr>
            </thead>
            <tbody>
              {rankingFiltrado.length===0
                ? <tr><td colSpan={8} style={{ padding:40,textAlign:"center",color:"rgba(255,255,255,0.25)",fontSize:13 }}>Nenhum resultado para esta filial</td></tr>
                : rankingFiltrado.map((c,i)=>(
                  <tr key={`${c.codigo_cliente}-${c.filial}`} style={{ borderBottom:"1px solid rgba(255,255,255,0.04)",transition:"background 0.15s",cursor:"pointer" }}
                    onClick={()=>setClienteSelecionado(c)}
                    onMouseEnter={e=>e.currentTarget.style.background="rgba(167,139,250,0.06)"}
                    onMouseLeave={e=>e.currentTarget.style.background="transparent"}>
                    <td style={{ padding:"13px 16px",color:"rgba(255,255,255,0.25)",fontWeight:600 }}>{i+1}</td>
                    <td style={{ padding:"13px 16px" }}>
                      <div style={{ fontWeight:600,color:"#a78bfa" }}>{c.nome_cliente}</div>
                      <div style={{ fontSize:11,color:"rgba(255,255,255,0.3)",fontFamily:"monospace" }}>{c.codigo_cliente}</div>
                    </td>
                    <td style={{ padding:"13px 16px",color:"rgba(255,255,255,0.5)" }}>{c.filial}</td>
                    <td style={{ padding:"13px 16px",textAlign:"right",fontWeight:700,color:"#a78bfa",fontSize:15 }}>{c.total_eventos}</td>
                    <td style={{ padding:"13px 16px",textAlign:"right",color:"rgba(255,255,255,0.55)" }}>{c.mensalidade?formatCurrency(c.mensalidade):<span style={{ color:"rgba(255,255,255,0.2)" }}>—</span>}</td>
                    <td style={{ padding:"13px 16px",textAlign:"right",color:"#fb923c",fontWeight:600 }}>{formatCurrency(c.custo_operacional)}</td>
                    <td style={{ padding:"13px 16px",textAlign:"right",fontWeight:700,color:!c.mensalidade?"rgba(255,255,255,0.2)":c.saldo<0?"#f87171":"#34d399" }}>{c.mensalidade?formatCurrency(c.saldo):"—"}</td>
                    <td style={{ padding:"13px 16px",textAlign:"center" }}><StatusBadge status={c.status_financeiro} /></td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
      </Card>
      {clienteSelecionado&&(
        <ClienteModal cliente={clienteSelecionado} dispatches={dispatches} onClose={()=>setClienteSelecionado(null)} supabaseClient={supabaseClient} isPortaria={true} />
      )}
    </>
  );
}

// ─── Dashboard Tab ────────────────────────────────────────────────────────────
function DashboardTab({ clients, dispatches }) {
  const [filialFiltro, setFilialFiltro] = useState("Todas");
  const [cidadeFiltro, setCidadeFiltro] = useState("Todas");
  const [clienteSelecionado, setClienteSelecionado] = useState(null);
  const [pagina, setPagina] = useState(1);
  const [periodoFiltro, setPeriodoFiltro] = useState("tudo"); // "tudo" | "mes_atual" | "3meses" | "6meses" | "custom"
  const [mesCustom, setMesCustom] = useState("");
  const PER_PAGE = 15;

  useEffect(()=>{ setCidadeFiltro("Todas"); setPagina(1); },[filialFiltro]);
  useEffect(()=>{ setPagina(1); },[cidadeFiltro, periodoFiltro, mesCustom]);

  // Meses disponíveis para o select custom
  const mesesDisponiveis = useMemo(()=>{
    const s = new Set();
    for (const d of dispatches) {
      const dt = parseDataHora(d.data_hora);
      if (dt) s.add(getMonthKey(dt));
    }
    return Array.from(s).filter(Boolean).sort().reverse();
  }, [dispatches]);

  // Filtra dispatches pelo período selecionado
  const dispatchesPeriodo = useMemo(()=>{
    if (periodoFiltro === "tudo") return dispatches;
    const agora = new Date();
    return dispatches.filter(d => {
      const dt = parseDataHora(d.data_hora);
      if (!dt) return false;
      if (periodoFiltro === "mes_atual") {
        return getMonthKey(dt) === getMonthKey(agora);
      }
      if (periodoFiltro === "3meses") {
        const limite = new Date(agora); limite.setMonth(limite.getMonth() - 2);
        return getMonthKey(dt) >= getMonthKey(limite);
      }
      if (periodoFiltro === "6meses") {
        const limite = new Date(agora); limite.setMonth(limite.getMonth() - 5);
        return getMonthKey(dt) >= getMonthKey(limite);
      }
      if (periodoFiltro === "custom" && mesCustom) {
        return getMonthKey(dt) === mesCustom;
      }
      return true;
    });
  }, [dispatches, periodoFiltro, mesCustom]);

  // Label do período ativo
  const labelPeriodo = useMemo(()=>{
    if (periodoFiltro === "tudo")      return null;
    if (periodoFiltro === "mes_atual") return monthLabel(getMonthKey(new Date()));
    if (periodoFiltro === "3meses")    return "Últimos 3 meses";
    if (periodoFiltro === "6meses")    return "Últimos 6 meses";
    if (periodoFiltro === "custom" && mesCustom) return monthLabel(mesCustom);
    return null;
  }, [periodoFiltro, mesCustom]);

  const cidadesDisponiveis = useMemo(()=>{
    if (filialFiltro==="Todas") return [];
    const cidades = new Set(clients.filter(c=>c.filial===filialFiltro&&c.cidade).map(c=>String(c.cidade).trim().toUpperCase()).filter(Boolean));
    if (cidades.size<=1) return [];
    return ["Todas",...Array.from(cidades).sort()];
  },[clients,filialFiltro]);

  const { ranking, kpis, porFilial, eventoFrequente, filiais } = useMemo(()=>{
    if (clients.length===0&&dispatchesPeriodo.filter(d=>!d.portaria_inteligente).length===0)
      return { ranking:[],kpis:null,porFilial:[],eventoFrequente:[],filiais:["Todas"] };
    const normalDispatches=dispatchesPeriodo.filter(d=>!d.portaria_inteligente);
    const dispMap={},filialMap={},eventoMap={};
    for (const d of normalDispatches) {
      const key=`${d.codigo_cliente}||${d.filial}`;
      dispMap[key]=(dispMap[key]||0)+1;
      if (d.filial) filialMap[d.filial]=(filialMap[d.filial]||0)+1;
      if (d.evento) eventoMap[d.evento]=(eventoMap[d.evento]||0)+1;
    }
    const baseClients=clients.length>0?clients:Object.entries(dispMap).map(([key])=>{
      const [codigo_cliente,filial]=key.split("||");
      return { codigo_cliente,filial,nome_cliente:codigo_cliente,mensalidade:0,status:"ativo" };
    });
    const rankingAll=baseClients.map(c=>{
      const key=`${c.codigo_cliente}||${c.filial}`;
      const totalDesl=dispMap[key]||0;
      const custo=totalDesl*CUSTO_FISCAL;
      const mens=c.mensalidade||0;
      return { ...c,total_deslocamentos:totalDesl,custo_operacional:custo,lucro_real:mens-custo,status_financeiro:calcStatus(mens,custo) };
    }).sort((a,b)=>b.total_deslocamentos-a.total_deslocamentos);
    const totalDesl=rankingAll.reduce((s,r)=>s+r.total_deslocamentos,0);
    const filiaisSet=["Todas",...new Set([...baseClients.map(c=>c.filial),...normalDispatches.map(d=>d.filial)].filter(Boolean))];
    return {
      ranking:rankingAll,
      kpis:{ totalClientes:baseClients.length, totalDeslocamentos:totalDesl, custoOperacionalTotal:totalDesl*CUSTO_FISCAL, clientesEmPrejuizo:rankingAll.filter(r=>r.status_financeiro==="PREJUÍZO").length, clientesEmRisco:rankingAll.filter(r=>r.status_financeiro==="RISCO").length, clientesSemDados:rankingAll.filter(r=>r.status_financeiro==="SEM DADOS").length },
      filiais:filiaisSet,
      porFilial:Object.entries(filialMap).map(([filial,total])=>({filial,total})).sort((a,b)=>b.total-a.total),
      eventoFrequente:Object.entries(eventoMap).map(([evento,total])=>({evento,total})).sort((a,b)=>b.total-a.total).slice(0,7),
    };
  },[clients,dispatchesPeriodo]);

  const rankingPorFilial = useMemo(()=>{
    let base=filialFiltro==="Todas"?ranking:ranking.filter(c=>c.filial===filialFiltro);
    if (cidadeFiltro!=="Todas") base=base.filter(c=>c.cidade&&String(c.cidade).trim().toUpperCase()===cidadeFiltro);
    return base;
  },[ranking,filialFiltro,cidadeFiltro]);

  const rankingFiltrado = useMemo(()=>{
    const start=(pagina-1)*PER_PAGE;
    return rankingPorFilial.slice(start,start+PER_PAGE);
  },[rankingPorFilial,pagina]);

  const kpisFiltrados = useMemo(()=>{
    const base=rankingPorFilial;
    const totalDesl=base.reduce((s,c)=>s+c.total_deslocamentos,0);
    return { totalClientes:base.length, totalDeslocamentos:totalDesl, custoOperacionalTotal:totalDesl*CUSTO_FISCAL, clientesEmPrejuizo:base.filter(r=>r.status_financeiro==="PREJUÍZO").length, clientesEmRisco:base.filter(r=>r.status_financeiro==="RISCO").length, clientesSemDados:base.filter(r=>r.status_financeiro==="SEM DADOS").length };
  },[rankingPorFilial]);

  if (!kpis) return <EmptyState icon="📊" title="Nenhum dado importado ainda" sub="Vá até a aba Importação e carregue suas planilhas." />;
  if (dispatches.filter(d=>!d.portaria_inteligente).length===0) return <EmptyState icon="🚗" title="Clientes importados! Agora importe os deslocamentos." sub="Vá até a aba Importação e carregue a planilha de deslocamentos." />;

  const btnPeriodo = (val, label) => (
    <button
      onClick={()=>{ setPeriodoFiltro(val); if(val!=="custom") setMesCustom(""); }}
      style={{ padding:"7px 16px", borderRadius:99, fontSize:12, fontWeight:600, cursor:"pointer", transition:"all 0.15s",
        border: periodoFiltro===val ? "1px solid #38bdf8" : "1px solid rgba(255,255,255,0.1)",
        background: periodoFiltro===val ? "rgba(56,189,248,0.15)" : "rgba(255,255,255,0.04)",
        color: periodoFiltro===val ? "#38bdf8" : "rgba(255,255,255,0.45)" }}>
      {label}
    </button>
  );

  return (
    <>
      <ClienteModal cliente={clienteSelecionado} dispatches={dispatchesPeriodo} onClose={()=>setClienteSelecionado(null)} supabaseClient={supabaseClient} />

      {/* ── Alertas Automáticos ── */}
      <AlertasPanel clients={clients} dispatches={dispatches} />

      {/* ── Filtro de Período ── */}
      <div style={{ marginBottom:20, padding:"14px 18px", borderRadius:14, border:"1px solid rgba(255,255,255,0.08)", background:"rgba(255,255,255,0.03)", display:"flex", alignItems:"center", gap:10, flexWrap:"wrap" }}>
        <span style={{ fontSize:11, fontWeight:700, letterSpacing:"0.1em", textTransform:"uppercase", color:"rgba(255,255,255,0.35)", marginRight:4 }}>📅 Período</span>
        {btnPeriodo("tudo",      "🔁 Tudo")}
        {btnPeriodo("mes_atual", "📌 Mês atual")}
        {btnPeriodo("3meses",    "📊 3 meses")}
        {btnPeriodo("6meses",    "📈 6 meses")}
        <div style={{ display:"flex", alignItems:"center", gap:8 }}>
          <button
            onClick={()=>setPeriodoFiltro("custom")}
            style={{ padding:"7px 16px", borderRadius:99, fontSize:12, fontWeight:600, cursor:"pointer", transition:"all 0.15s",
              border: periodoFiltro==="custom" ? "1px solid #38bdf8" : "1px solid rgba(255,255,255,0.1)",
              background: periodoFiltro==="custom" ? "rgba(56,189,248,0.15)" : "rgba(255,255,255,0.04)",
              color: periodoFiltro==="custom" ? "#38bdf8" : "rgba(255,255,255,0.45)" }}>
            🗓 Mês específico
          </button>
          {periodoFiltro==="custom" && (
            <select value={mesCustom} onChange={e=>setMesCustom(e.target.value)}
              style={{ padding:"6px 12px", borderRadius:99, border:"1px solid rgba(56,189,248,0.4)", background:"rgba(56,189,248,0.1)", color:"#38bdf8", fontSize:12, fontWeight:700, outline:"none", cursor:"pointer" }}>
              <option value="">— escolha o mês —</option>
              {mesesDisponiveis.map(m=><option key={m} value={m}>{monthLabel(m)}</option>)}
            </select>
          )}
        </div>

        {/* Badge do período ativo */}
        {labelPeriodo && (
          <div style={{ marginLeft:"auto", display:"flex", alignItems:"center", gap:8, padding:"5px 14px", borderRadius:99, background:"rgba(56,189,248,0.12)", border:"1px solid rgba(56,189,248,0.3)" }}>
            <span style={{ fontSize:11, fontWeight:700, color:"#38bdf8" }}>Mostrando: {labelPeriodo}</span>
            <span style={{ fontSize:11, color:"rgba(56,189,248,0.6)" }}>· {dispatchesPeriodo.filter(d=>!d.portaria_inteligente).length.toLocaleString("pt-BR")} desl.</span>
            <button onClick={()=>{ setPeriodoFiltro("tudo"); setMesCustom(""); }}
              style={{ background:"none", border:"none", color:"rgba(56,189,248,0.6)", cursor:"pointer", fontSize:14, lineHeight:1, padding:0 }}>×</button>
          </div>
        )}
      </div>

      {(()=>{
        const totalMens=rankingPorFilial.reduce((s,c)=>s+(c.mensalidade||0),0);
        const totalSaldo=rankingPorFilial.reduce((s,c)=>s+(c.mensalidade?c.lucro_real:0),0);
        return (
          <>
            <div className="grid-4" style={{ marginBottom:12 }}>
              <KPICard label="Clientes"          value={kpisFiltrados.totalClientes}         sub={labelPeriodo||"total geral"} icon="👥" accent="#38bdf8" />
              <KPICard label="Deslocamentos"     value={kpisFiltrados.totalDeslocamentos}    sub={labelPeriodo||"total registrado"} icon="🚗" accent="#818cf8" />
              <KPICard label="Mensalidade Total" value={formatCurrency(totalMens)}           sub={`${rankingPorFilial.filter(c=>c.mensalidade>0).length} clientes c/ mensalidade`} icon="💳" accent="#34d399" />
              <KPICard label="Saldo Total"       value={formatCurrency(totalSaldo)}          sub="mensalidade − custo op." icon={totalSaldo>=0?"✅":"❌"} accent={totalSaldo>=0?"#34d399":"#f87171"} />
            </div>
            <div className="grid-4" style={{ marginBottom:28 }}>
              <KPICard label="Custo Operacional" value={formatCurrency(kpisFiltrados.custoOperacionalTotal)} sub={`@ R$ ${CUSTO_FISCAL}/desl.`} icon="💰" accent="#fb923c" />
              <KPICard label="Em Prejuízo"       value={kpisFiltrados.clientesEmPrejuizo}   sub="com mensalidade" icon="🔴" accent="#f87171" />
              <KPICard label="Em Risco"          value={kpisFiltrados.clientesEmRisco}       sub="com mensalidade" icon="🟡" accent="#fbbf24" />
              <KPICard label="Sem Mensalidade"   value={kpisFiltrados.clientesSemDados}      sub="aguardando cadastro" icon="⚪" accent="#94a3b8" />
            </div>
          </>
        );
      })()}

      {/* Resumo por mês — sempre mostra tudo (não filtra por período) */}
      <MesesResumo dispatches={dispatches} filialFiltro={filialFiltro} cidadeFiltro={cidadeFiltro} codigosFiltrados={cidadeFiltro!=="Todas"?new Set(rankingPorFilial.map(c=>`${c.codigo_cliente}||${c.filial}`)):null} tipo="normal" clients={clients} />

      <div className="grid-2">
        <Card><div style={{ padding:20 }}>
          <SectionLabel>Deslocamentos por Filial{labelPeriodo?` — ${labelPeriodo}`:""}</SectionLabel>
          <BarChart data={(filialFiltro==="Todas"?porFilial:porFilial.filter(f=>f.filial===filialFiltro)).map(d=>({label:d.filial.slice(0,14),value:d.total}))} label="Deslocamentos" height={220} />
        </div></Card>
        <Card><div style={{ padding:20 }}>
          <SectionLabel>Eventos Mais Frequentes{labelPeriodo?` — ${labelPeriodo}`:""}</SectionLabel>
          <DonutChart data={(()=>{
            const base=dispatchesPeriodo.filter(d=>{ if(d.portaria_inteligente)return false; if(filialFiltro!=="Todas"&&d.filial!==filialFiltro)return false; return true; });
            const m={}; for(const d of base){if(d.evento)m[d.evento]=(m[d.evento]||0)+1;}
            return Object.entries(m).map(([evento,total])=>({label:evento.slice(0,24),value:total})).sort((a,b)=>b.value-a.value).slice(0,7);
          })()} height={220} />
        </div></Card>
      </div>

      <Card>
        <div style={{ borderBottom:"1px solid rgba(255,255,255,0.07)",padding:"16px 20px" }}>
          <div style={{ marginBottom:12, display:"flex", justifyContent:"space-between", alignItems:"flex-start", flexWrap:"wrap", gap:12 }}>
            <div>
              <SectionLabel>Ranking de Clientes{labelPeriodo?` — ${labelPeriodo}`:""}</SectionLabel>
              <p style={{ fontSize:11,color:"rgba(255,255,255,0.25)",margin:"-8px 0 0" }}>Ordenado por deslocamentos · Custo @ R$ {CUSTO_FISCAL}/desl. · Portaria Inteligente excluída</p>
            </div>
            {periodoFiltro!=="tudo" && (
              <div style={{ padding:"6px 14px", borderRadius:10, background:"rgba(56,189,248,0.08)", border:"1px solid rgba(56,189,248,0.2)", fontSize:11, color:"#38bdf8", fontWeight:600 }}>
                📅 {labelPeriodo}
              </div>
            )}
          </div>
          <div style={{ display:"flex",gap:6,flexWrap:"wrap" }}>
            {filiais.map(f=><FilterBtn key={f} active={filialFiltro===f} onClick={()=>{ setFilialFiltro(f); setPagina(1); }}>{f}</FilterBtn>)}
          </div>
          {cidadesDisponiveis.length>0&&(
            <div style={{ display:"flex",gap:6,flexWrap:"wrap",marginTop:10,paddingTop:10,borderTop:"1px solid rgba(255,255,255,0.06)",alignItems:"center" }}>
              <span style={{ fontSize:10,fontWeight:700,letterSpacing:"0.12em",textTransform:"uppercase",color:"rgba(255,255,255,0.3)",marginRight:4 }}>🏙 Cidade</span>
              {cidadesDisponiveis.map(c=><FilterBtn key={c} active={cidadeFiltro===c} onClick={()=>setCidadeFiltro(c)}>{c==="Todas"?"Todas as cidades":c}</FilterBtn>)}
            </div>
          )}
        </div>
        <div style={{ overflowX:"auto" }}>
          <table style={{ width:"100%",borderCollapse:"collapse",fontSize:13 }}>
            <thead>
              <tr style={{ borderBottom:"1px solid rgba(255,255,255,0.05)" }}>
                {["#","Cliente","Filial","Deslocamentos","Mensalidade","Custo Op.","Saldo","Status"].map(h=>(
                  <th key={h} style={{ padding:"12px 16px",textAlign:["Deslocamentos","Mensalidade","Custo Op.","Saldo"].includes(h)?"right":h==="Status"?"center":"left",fontSize:10,fontWeight:700,letterSpacing:"0.1em",textTransform:"uppercase",color:"rgba(255,255,255,0.25)" }}>{h}</th>
                ))}
              </tr>
            </thead>
            <tbody>
              {rankingFiltrado.length===0
                ? <tr><td colSpan={8} style={{ padding:40,textAlign:"center",color:"rgba(255,255,255,0.25)",fontSize:13 }}>Nenhum cliente com deslocamentos{labelPeriodo?` em ${labelPeriodo}`:""}</td></tr>
                : rankingFiltrado.map((c,i)=>{
                  const numGlobal=(pagina-1)*PER_PAGE+i+1;
                  return (
                    <tr key={`${c.codigo_cliente}-${c.filial}-${i}`} onClick={()=>setClienteSelecionado(c)} style={{ borderBottom:"1px solid rgba(255,255,255,0.04)",transition:"background 0.15s",cursor:"pointer" }}
                      onMouseEnter={e=>e.currentTarget.style.background="rgba(56,189,248,0.06)"}
                      onMouseLeave={e=>e.currentTarget.style.background="transparent"}>
                      <td style={{ padding:"13px 16px",color:"rgba(255,255,255,0.25)",fontWeight:600 }}>{numGlobal}</td>
                      <td style={{ padding:"13px 16px" }}>
                        <div style={{ fontWeight:600,color:"#38bdf8" }}>{c.nome_cliente}</div>
                        <div style={{ fontSize:11,color:"rgba(255,255,255,0.3)",fontFamily:"monospace" }}>{c.codigo_cliente}</div>
                      </td>
                      <td style={{ padding:"13px 16px",color:"rgba(255,255,255,0.5)" }}>{c.filial}</td>
                      <td style={{ padding:"13px 16px",textAlign:"right",fontWeight:700,color:"#38bdf8" }}>{c.total_deslocamentos}</td>
                      <td style={{ padding:"13px 16px",textAlign:"right",color:"rgba(255,255,255,0.55)" }}>{c.mensalidade?formatCurrency(c.mensalidade):<span style={{ color:"rgba(255,255,255,0.2)" }}>—</span>}</td>
                      <td style={{ padding:"13px 16px",textAlign:"right",color:"#fb923c",fontWeight:600 }}>{formatCurrency(c.custo_operacional)}</td>
                      <td style={{ padding:"13px 16px",textAlign:"right",fontWeight:700,color:!c.mensalidade?"rgba(255,255,255,0.2)":c.lucro_real<0?"#f87171":"#34d399" }}>{formatSaldo(c.mensalidade,c.lucro_real)}</td>
                      <td style={{ padding:"13px 16px",textAlign:"center" }}><StatusBadge status={c.status_financeiro} /></td>
                    </tr>
                  );
                })
              }
              {rankingFiltrado.length>0&&(()=>{
                const totalDesl=rankingPorFilial.reduce((s,c)=>s+c.total_deslocamentos,0);
                const totalMens=rankingPorFilial.reduce((s,c)=>s+(c.mensalidade||0),0);
                const totalCusto=rankingPorFilial.reduce((s,c)=>s+c.custo_operacional,0);
                const totalSaldo=rankingPorFilial.reduce((s,c)=>s+(c.mensalidade?c.lucro_real:0),0);
                const temMens=rankingPorFilial.some(c=>c.mensalidade>0);
                return (
                  <tr style={{ borderTop:"2px solid rgba(255,255,255,0.1)",background:"rgba(255,255,255,0.03)" }}>
                    <td colSpan={3} style={{ padding:"13px 16px",fontWeight:700,color:"rgba(255,255,255,0.5)",fontSize:11,letterSpacing:"0.08em",textTransform:"uppercase" }}>Total ({rankingPorFilial.length} clientes)</td>
                    <td style={{ padding:"13px 16px",textAlign:"right",fontWeight:800,color:"#38bdf8",fontSize:15 }}>{totalDesl}</td>
                    <td style={{ padding:"13px 16px",textAlign:"right",fontWeight:700,color:"#34d399" }}>{temMens?formatCurrency(totalMens):<span style={{ color:"rgba(255,255,255,0.2)" }}>—</span>}</td>
                    <td style={{ padding:"13px 16px",textAlign:"right",fontWeight:700,color:"#fb923c" }}>{formatCurrency(totalCusto)}</td>
                    <td style={{ padding:"13px 16px",textAlign:"right",fontWeight:800,color:!temMens?"rgba(255,255,255,0.2)":totalSaldo>=0?"#34d399":"#f87171",fontSize:14 }}>{temMens?formatCurrency(totalSaldo):"—"}</td>
                    <td></td>
                  </tr>
                );
              })()}
            </tbody>
          </table>
        </div>
        <Pagination total={rankingPorFilial.length} page={pagina} perPage={PER_PAGE} onChange={p=>setPagina(p)} />
      </Card>
    </>
  );
}

// ─── Mensalidades Padrão ──────────────────────────────────────────────────────
const MENSALIDADES_PADRAO = [
  { filialKey:"SIDERALTECH",                              valor:67.44 },
  { filialKey:"VISION SEGURANCA",                         valor:66.00 },
  { filialKey:"2 PROGUARD",                               valor:65.00 },
  { filialKey:"4 PRIORIDADE SERVICOS TERCEIRIZADOS LTDA", valor:65.00 },
  { filialKey:"OVERTEC",                                  valor:72.21 },
  { filialKey:"3 LUXUS SERVICOS E TECNOLOGIA LTDA",       valor:88.44 },
];

function MensalidadesPadraoCard({ clients, supabaseClient, onRefresh }) {
  const [aplicando, setAplicando] = useState(false);
  const [preview, setPreview]     = useState(null);
  const [detalhes, setDetalhes]   = useState("");

  const resumo = useMemo(()=>{
    return MENSALIDADES_PADRAO.map(({ filialKey, valor })=>{
      const matchFn = c=>c.filial&&(c.filial.toUpperCase()===filialKey.toUpperCase()||c.filial.toUpperCase().includes(filialKey.toUpperCase().split(" ")[0]));
      const semMens = clients.filter(c=>matchFn(c)&&(!c.mensalidade||parseFloat(c.mensalidade)===0));
      const comMens = clients.filter(c=>matchFn(c)&&parseFloat(c.mensalidade)>0);
      return { filialKey, valor, semMens:semMens.length, comMens:comMens.length, clientes:semMens };
    });
  },[clients]);

  const totalAfetados = resumo.reduce((s,r)=>s+r.semMens,0);

  async function aplicarMensalidades() {
    if (totalAfetados===0) return;
    setAplicando(true);
    setDetalhes("");
    let totalSalvo=0, log=[];
    try {
      for (const { filialKey, valor, clientes } of resumo) {
        if (clientes.length===0) continue;
        const registros = clientes.map(c=>({ id:c.id, codigo_cliente:c.codigo_cliente, nome_cliente:c.nome_cliente||"", filial:c.filial, mensalidade:valor, status:c.status||"ativo" }));
        for (let i=0;i<registros.length;i+=100) {
          try {
            await supaQuery(()=>supabaseClient.from("clients").upsert(registros.slice(i,i+100),{ onConflict:"codigo_cliente,filial" }));
            totalSalvo+=registros.slice(i,i+100).length;
            log.push(`✅ ${filialKey}: ${registros.slice(i,i+100).length} atualizados @ R$ ${valor.toFixed(2)}`);
          } catch(e) {
            log.push(`❌ ${filialKey}: ${e.message}`);
          }
        }
      }
      setDetalhes(log.join("\n"));
      if (totalSalvo>0) {
        toast(`✅ ${totalSalvo} clientes com mensalidade atualizada!`, "success");
        await onRefresh();
      } else {
        toast("Nenhum cliente foi atualizado", "error");
      }
    } catch(e) {
      toast("Erro inesperado: " + e.message, "error");
    }
    setAplicando(false);
    setPreview(null);
  }

  if (clients.length===0) return null;

  return (
    <div style={{ borderRadius:16,border:"1px solid rgba(52,211,153,0.2)",background:"rgba(52,211,153,0.03)",padding:24,marginBottom:20 }}>
      <div style={{ display:"flex",justifyContent:"space-between",alignItems:"flex-start",marginBottom:16,flexWrap:"wrap",gap:12 }}>
        <div>
          <div style={{ fontSize:13,fontWeight:700,color:"#34d399",marginBottom:4 }}>💳 Mensalidades Padrão por Filial</div>
          <div style={{ fontSize:11,color:"rgba(255,255,255,0.4)" }}>
            Aplica valores fixos nos clientes <strong style={{ color:"#fff" }}>sem mensalidade cadastrada</strong> · {totalAfetados} clientes serão afetados
          </div>
        </div>
        <div style={{ display:"flex",gap:8,alignItems:"center" }}>
          <button onClick={()=>setPreview(p=>p?null:true)} style={{ padding:"7px 14px",borderRadius:8,border:"1px solid rgba(52,211,153,0.3)",background:"rgba(52,211,153,0.08)",color:"#34d399",cursor:"pointer",fontSize:12,fontWeight:600 }}>
            {preview?"Ocultar":"👁 Ver prévia"}
          </button>
          <LoadingBtn onClick={aplicarMensalidades} loading={aplicando} disabled={totalAfetados===0} color={totalAfetados===0?"rgba(52,211,153,0.2)":"#34d399"}>
            Aplicar ({totalAfetados} clientes)
          </LoadingBtn>
        </div>
      </div>
      <div style={{ display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(260px,1fr))",gap:10 }}>
        {resumo.map(({ filialKey, valor, semMens, comMens })=>(
          <div key={filialKey} style={{ borderRadius:10,border:semMens>0?"1px solid rgba(52,211,153,0.2)":"1px solid rgba(255,255,255,0.06)",background:semMens>0?"rgba(52,211,153,0.05)":"rgba(255,255,255,0.02)",padding:"10px 14px",display:"flex",justifyContent:"space-between",alignItems:"center" }}>
            <div>
              <div style={{ fontSize:12,fontWeight:700,color:semMens>0?"#fff":"rgba(255,255,255,0.4)" }}>{filialKey.length>30?filialKey.slice(0,30)+"…":filialKey}</div>
              <div style={{ fontSize:10,color:"rgba(255,255,255,0.35)",marginTop:2 }}>
                {semMens>0?<span style={{ color:"#34d399" }}>{semMens} sem mens.</span>:<span>✅ todos cadastrados</span>}
                {comMens>0&&<span style={{ marginLeft:6,color:"rgba(255,255,255,0.25)" }}>· {comMens} já têm</span>}
              </div>
            </div>
            <div style={{ textAlign:"right" }}>
              <div style={{ fontSize:14,fontWeight:800,color:semMens>0?"#34d399":"rgba(255,255,255,0.3)" }}>R$ {valor.toFixed(2).replace(".",",")}</div>
              <div style={{ fontSize:9,color:"rgba(255,255,255,0.25)" }}>por cliente</div>
            </div>
          </div>
        ))}
      </div>
      {detalhes&&(
        <div style={{ marginTop:14,borderRadius:10,border:"1px solid rgba(255,255,255,0.08)",background:"rgba(0,0,0,0.3)",padding:"12px 16px" }}>
          <div style={{ fontSize:10,fontWeight:700,letterSpacing:"0.1em",textTransform:"uppercase",color:"rgba(255,255,255,0.3)",marginBottom:8 }}>Log de execução</div>
          {detalhes.split("\n").map((linha,i)=>(
            <div key={i} style={{ fontSize:11,color:linha.startsWith("✅")?"#34d399":"#f87171",fontFamily:"monospace",marginBottom:2 }}>{linha}</div>
          ))}
        </div>
      )}
    </div>
  );
}

// ─── Import Tab ───────────────────────────────────────────────────────────────
function ImportTab({ onImportClients, onImportDispatches, clients, dispatches, supabaseClient, onRefresh }) {
  const clientRef   = useRef();
  const dispatchRef = useRef();
  const [clientPreview,    setClientPreview]    = useState(null);
  const [dispatchPreview,  setDispatchPreview]  = useState(null);
  const [clientError,      setClientError]      = useState("");
  const [dispatchError,    setDispatchError]    = useState("");
  const [clientFileName,   setClientFileName]   = useState("");
  const [dispatchFileName, setDispatchFileName] = useState("");
  const [filialForcada,    setFilialForcada]    = useState("");
  const [importandoClientes,    setImportandoClientes]    = useState(false);
  const [importandoDespachos,   setImportandoDespachos]   = useState(false);

  function readExcel(file, onSuccess, onError) {
    const reader = new FileReader();
    reader.onload = e => {
      try {
        const wb = XLSX.read(e.target.result, {
          type: "binary",
          cellText: true,   // força leitura como texto
          cellDates: true,  // mantém datas como Date
          raw: false,       // não usa valor bruto numérico
        });
        const sheetName = wb.SheetNames.find(n=>
          n.toLowerCase().includes("deslocamento")||
          n.toLowerCase().includes("viatura")||
          n.toLowerCase().includes("contas")||
          n.toLowerCase().includes("conta")
        )||wb.SheetNames[0];
        const ws   = wb.Sheets[sheetName];
        // defval "" e raw:false garante que números não sobrescrevam o texto formatado
        const rows = XLSX.utils.sheet_to_json(ws, {
          defval: "",
          raw: false,       // usa o valor formatado (texto) em vez do número
        });
        onSuccess(rows, wb.SheetNames);
      } catch(err) { onError("Erro ao ler o arquivo: " + err.message); }
    };
    reader.onerror = () => onError("Não foi possível ler o arquivo. Verifique se não está corrompido.");
    reader.readAsBinaryString(file);
  }

  function handleClientFile(e) {
    const file=e.target.files[0]; if (!file) return;
    setClientError(""); setClientFileName(file.name);
    readExcel(file, rows=>{
      const mapped = rows.map(r=>{
        const empresaRaw=String(r["Empresa"]||r["empresa"]||r["Filial"]||r["filial"]||"");
        const cidadeRaw =String(r["Cidade"]||r["cidade"]||r["CIDADE"]||r["Município"]||r["Municipio"]||"");

        // ── Força leitura do código como string, preservando zeros e letras ──
        const codigoRaw = r["Conta"]||r["conta"]||r["CONTA"]||"";
        let codigo = "";
        if (typeof codigoRaw === "number") {
          // Excel converteu para número — reconstrói o hex com zero à esquerda
          codigo = codigoRaw.toString(16).toUpperCase().padStart(4, "0");
        } else {
          codigo = String(codigoRaw).trim();
        }

        return {
          codigo_cliente: codigo,
          nome_cliente:   limparFantasia(String(r["Fantasia (Razão Social)"]||r["Fantasia"]||r["Razão Social"]||r["fantasia"]||"")),
          filial:         limparEmpresa(empresaRaw,cidadeRaw),
          cidade:         cidadeRaw.trim(),
          mensalidade:    parseFloat(String(r["Mensalidade"]||r["mensalidade"]||"0").replace(",","."))||0,
          status:"ativo",
        };
      }).filter(r=>r.codigo_cliente&&r.nome_cliente);
      if (mapped.length===0) { setClientError('Nenhum cliente encontrado. Verifique as colunas: "Conta", "Fantasia (Razão Social)", "Empresa".'); return; }
      setClientPreview(mapped);
    }, setClientError);
  }

  function handleDispatchFile(e) {
    const file=e.target.files[0]; if (!file) return;
    setDispatchError(""); setDispatchFileName(file.name);
    readExcel(file, rows=>{
      const mapped = rows.map(r=>{
        // ── Força leitura do código como string, preservando zeros e letras ──
        const codigoRaw = r["Código da conta"]||r["Codigo da conta"]||r["Conta"]||r["conta"]||r["codigo_cliente"]||"";
        let codigo = "";
        if (typeof codigoRaw === "number") {
          codigo = codigoRaw.toString(16).toUpperCase().padStart(4, "0");
        } else {
          codigo = String(codigoRaw).trim();
        }

        const empresaRaw  = String(r["Empresa"]||r["empresa"]||r["Filial"]||r["filial"]||"").trim();
        const cidadeRaw   = String(r["Cidade"]||r["cidade"]||r["CIDADE"]||r["Município"]||r["Municipio"]||"").trim();
        const fantasiaRaw = String(r["Fantasia (Razão social)"]||r["Fantasia"]||r["fantasia"]||"").trim();
        const evento      = String(r["Evento"]||r["evento"]||"").trim();
        const viatura     = String(r["Viatura"]||r["viatura"]||"").trim();
        const dataRaw     = r["Data de recepção"]||r["Data de recepcao"]||r["Data/Hora"]||r["Data"]||r["data_hora"]||"";
        let data_hora = "";
        if (dataRaw instanceof Date) data_hora=dataRaw.toLocaleString("pt-BR");
        else if (typeof dataRaw==="number"&&dataRaw>1000) {
          const d=new Date(new Date(1899,11,30).getTime()+dataRaw*86400000);
          data_hora=d.toLocaleString("pt-BR");
        } else data_hora=String(dataRaw).trim();

        let filial=limparEmpresa(empresaRaw,cidadeRaw);
        if (!cidadeRaw&&filial==="SECOPI TERESINA") {
          const clienteCadastrado=clients.find(c=>c.codigo_cliente===codigo);
          if (clienteCadastrado?.filial) filial=clienteCadastrado.filial;
        }
        if (filialForcada) filial=filialForcada;
        const portaria_inteligente=fantasiaRaw.toUpperCase().includes("PORTARIA INTELIGENTE");
        return { codigo_cliente:codigo, filial, nome_cliente:limparFantasia(fantasiaRaw), data_hora, evento, viatura, portaria_inteligente };
      }).filter(r=>r.codigo_cliente&&r.evento);

      if (mapped.length===0) { setDispatchError('Nenhum deslocamento encontrado. Verifique as colunas: "Código da conta", "Empresa", "Data de recepção", "Evento".'); return; }

      const mesesNoArquivo={};
      for (const r of mapped) {
        const dt=parseDataHora(r.data_hora);
        if (dt) { const mk=getMonthKey(dt); if (mk) mesesNoArquivo[mk]=(mesesNoArquivo[mk]||0)+1; }
      }
      const semanasNoArquivo=new Set();
      for (const r of mapped) {
        const dt=parseDataHora(r.data_hora);
        if (dt) semanasNoArquivo.add(getWeekKey(dt));
      }
      const semanasJaImportadas=new Set();
      for (const d of dispatches) {
        const dt=parseDataHora(d.data_hora);
        if (dt) { const wk=getWeekKey(dt); if (semanasNoArquivo.has(wk)) semanasJaImportadas.add(wk); }
      }
      const mesesJaImportados={};
      for (const wk of semanasJaImportadas) {
        const [wy,wm]=wk.split("-");
        const mk=`${wy}-${wm}`;
        if (mesesNoArquivo[mk]) mesesJaImportados[mk]=true;
      }
      const normais=mapped.filter(r=>!r.portaria_inteligente).length;
      const portaria=mapped.filter(r=>r.portaria_inteligente).length;
      setDispatchPreview({ rows:mapped, normais, portaria, total:rows.length, mesesNoArquivo, mesesJaImportados });
    }, setDispatchError);
  }

  async function confirmClients() {
    setImportandoClientes(true);
    try {
      await onImportClients(clientPreview);
      setClientPreview(null); setClientFileName("");
      if (clientRef.current) clientRef.current.value="";
    } catch(e) {
      toast("Erro ao importar clientes: " + e.message, "error");
    } finally {
      setImportandoClientes(false);
    }
  }

  async function confirmDispatches() {
    setImportandoDespachos(true);
    try {
      await onImportDispatches(dispatchPreview.rows);
      setDispatchPreview(null); setDispatchFileName("");
      if (dispatchRef.current) dispatchRef.current.value="";
    } catch(e) {
      toast("Erro ao importar deslocamentos: " + e.message, "error");
    } finally {
      setImportandoDespachos(false);
    }
  }

  const card={ borderRadius:16,border:"1px solid rgba(255,255,255,0.08)",background:"rgba(255,255,255,0.04)",padding:24,marginBottom:20 };

  return (
    <div>
      {(clients.length>0||dispatches.length>0)&&(
        <div style={{ borderRadius:12,border:"1px solid rgba(56,189,248,0.2)",background:"rgba(56,189,248,0.05)",padding:"12px 18px",marginBottom:20,display:"flex",alignItems:"center",justifyContent:"space-between",gap:12 }}>
          <div style={{ display:"flex",alignItems:"center",gap:10 }}>
            <span style={{ fontSize:18 }}>💾</span>
            <div>
              <div style={{ fontSize:13,fontWeight:600,color:"#38bdf8" }}>Dados salvos no banco</div>
              <div style={{ fontSize:11,color:"rgba(255,255,255,0.3)",marginTop:2 }}>
                {clients.length} clientes · {dispatches.filter(d=>!d.portaria_inteligente).length} deslocamentos · {dispatches.filter(d=>d.portaria_inteligente).length} portaria inteligente
              </div>
            </div>
          </div>
          <div style={{ fontSize:11,color:"rgba(255,255,255,0.3)",textAlign:"right" }}>Reimporte abaixo para<br/>atualizar os dados</div>
        </div>
      )}
      <div style={{ display:"grid",gridTemplateColumns:"1fr 1fr 1fr",gap:16,marginBottom:24 }}>
        {[
          { label:"Clientes importados",         value:clients.length,                                        icon:"👥",color:"#38bdf8" },
          { label:"Deslocamentos normais",        value:dispatches.filter(d=>!d.portaria_inteligente).length, icon:"🚗",color:"#818cf8" },
          { label:"Eventos Portaria Inteligente", value:dispatches.filter(d=>d.portaria_inteligente).length,  icon:"🏢",color:"#a78bfa" },
        ].map(({ label,value,icon,color })=>(
          <div key={label} style={{ borderRadius:16,border:"1px solid rgba(255,255,255,0.08)",background:"rgba(255,255,255,0.04)",padding:20,display:"flex",alignItems:"center",gap:16 }}>
            <div style={{ width:44,height:44,borderRadius:12,background:`${color}18`,display:"flex",alignItems:"center",justifyContent:"center",fontSize:20 }}>{icon}</div>
            <div>
              <div style={{ fontSize:22,fontWeight:800,color:"#fff" }}>{value}</div>
              <div style={{ fontSize:11,color:"rgba(255,255,255,0.35)" }}>{label}</div>
            </div>
          </div>
        ))}
      </div>

      <div style={card}>
        <SectionLabel>📋 Importar Clientes</SectionLabel>
        <div style={{ borderRadius:10,border:"1px solid rgba(255,255,255,0.07)",background:"rgba(255,255,255,0.03)",padding:"12px 16px",marginBottom:16 }}>
          <div style={{ fontSize:11,color:"rgba(255,255,255,0.3)",marginBottom:8,fontWeight:600,textTransform:"uppercase",letterSpacing:"0.08em" }}>Colunas da planilha</div>
          <div style={{ display:"flex",flexWrap:"wrap",gap:6,alignItems:"center" }}>
            <ColTag color="#38bdf8">Conta</ColTag><span style={{ color:"rgba(255,255,255,0.2)",fontSize:11 }}>→ Código</span>
            <ColTag color="#38bdf8">Fantasia (Razão Social)</ColTag><span style={{ color:"rgba(255,255,255,0.2)",fontSize:11 }}>→ Nome</span>
            <ColTag color="#38bdf8">Empresa</ColTag><span style={{ color:"rgba(255,255,255,0.2)",fontSize:11 }}>→ Filial</span>
            <ColTag color="#ffffff50">Mensalidade</ColTag><span style={{ color:"rgba(255,255,255,0.2)",fontSize:10 }}>(opcional)</span>
          </div>
        </div>
        <DropZone color="#38bdf8" fileName={clientFileName} inputRef={clientRef} onChange={handleClientFile} label="Clique para selecionar a planilha de clientes" />
        {clientError&&<div style={{ marginTop:12,padding:"10px 14px",borderRadius:10,background:"#ef444420",border:"1px solid #ef444440",color:"#f87171",fontSize:12 }}>⚠️ {clientError}</div>}
        {clientPreview&&(
          <div style={{ marginTop:16 }}>
            <div style={{ fontSize:12,color:"rgba(255,255,255,0.4)",marginBottom:10 }}>✅ <strong style={{ color:"#34d399" }}>{clientPreview.length} clientes</strong> encontrados — prévia:</div>
            <div style={{ overflowX:"auto",borderRadius:10,border:"1px solid rgba(255,255,255,0.07)" }}>
              <table style={{ width:"100%",borderCollapse:"collapse",fontSize:12 }}>
                <thead><tr style={{ background:"rgba(255,255,255,0.04)" }}>{["Código","Nome","Filial","Cidade","Mensalidade"].map(h=><th key={h} style={{ padding:"8px 12px",textAlign:"left",color:"rgba(255,255,255,0.3)",fontSize:10,textTransform:"uppercase" }}>{h}</th>)}</tr></thead>
                <tbody>{clientPreview.slice(0,5).map((r,i)=>(
                  <tr key={i} style={{ borderTop:"1px solid rgba(255,255,255,0.05)" }}>
                    <td style={{ padding:"8px 12px",color:"#38bdf8",fontFamily:"monospace" }}>{r.codigo_cliente}</td>
                    <td style={{ padding:"8px 12px",color:"#fff" }}>{r.nome_cliente}</td>
                    <td style={{ padding:"8px 12px",color:"rgba(255,255,255,0.5)" }}>{r.filial}</td>
                    <td style={{ padding:"8px 12px",color:"#a78bfa" }}>{r.cidade||"—"}</td>
                    <td style={{ padding:"8px 12px",color:"rgba(255,255,255,0.5)" }}>{r.mensalidade?formatCurrency(r.mensalidade):"—"}</td>
                  </tr>
                ))}</tbody>
              </table>
            </div>
            <div style={{ display:"flex",gap:10,marginTop:14 }}>
              <LoadingBtn onClick={confirmClients} loading={importandoClientes} style={{ flex:1,padding:10,borderRadius:10 }}>
                ✅ Confirmar — {clientPreview.length} clientes
              </LoadingBtn>
              <button onClick={()=>{ setClientPreview(null); setClientFileName(""); if(clientRef.current)clientRef.current.value=""; }}
                style={{ padding:"10px 16px",borderRadius:10,border:"1px solid rgba(255,255,255,0.1)",background:"transparent",color:"rgba(255,255,255,0.4)",fontSize:13,cursor:"pointer" }}>
                Cancelar
              </button>
            </div>
          </div>
        )}
      </div>

      <div style={card}>
        <SectionLabel>🚗 Importar Deslocamentos</SectionLabel>
        <div style={{ borderRadius:10,border:"1px solid rgba(255,255,255,0.07)",background:"rgba(255,255,255,0.03)",padding:"12px 16px",marginBottom:16 }}>
          <div style={{ fontSize:11,color:"rgba(255,255,255,0.3)",marginBottom:8,fontWeight:600,textTransform:"uppercase",letterSpacing:"0.08em" }}>Colunas da planilha</div>
          <div style={{ display:"flex",flexWrap:"wrap",gap:6,alignItems:"center" }}>
            <ColTag color="#818cf8">Código da conta</ColTag>
            <ColTag color="#818cf8">Empresa</ColTag>
            <ColTag color="#818cf8">Data de recepção</ColTag>
            <ColTag color="#818cf8">Evento</ColTag>
            <ColTag color="#ffffff50">Viatura</ColTag>
            <ColTag color="#ffffff50">Fantasia (Razão social)</ColTag>
          </div>
        </div>
        <div style={{ marginBottom:14 }}>
          <div style={{ fontSize:11,fontWeight:700,textTransform:"uppercase",letterSpacing:"0.08em",color:"rgba(255,255,255,0.35)",marginBottom:8 }}>
            📌 Filial desta importação <span style={{ color:"#f87171",fontWeight:400,textTransform:"none",letterSpacing:0 }}>(obrigatório)</span>
          </div>
          <select value={filialForcada} onChange={e=>{ setFilialForcada(e.target.value); setDispatchPreview(null); setDispatchFileName(""); if(dispatchRef.current)dispatchRef.current.value=""; }}
            style={{ width:"100%",padding:"10px 14px",borderRadius:10,border:filialForcada?"1px solid rgba(129,140,248,0.5)":"1px solid rgba(239,68,68,0.5)",background:filialForcada?"rgba(129,140,248,0.08)":"rgba(239,68,68,0.06)",color:filialForcada?"#818cf8":"#f87171",fontSize:13,fontWeight:700,outline:"none",cursor:"pointer" }}>
            <option value="">— Selecione a filial antes de importar —</option>
            {getFiliaisKeys().map(chave => (
              <option key={chave} value={chave}>{getNomeFilial(chave)}</option>
            ))}
          </select>
        </div>
        <DropZone color={filialForcada?"#818cf8":"#ef4444"} fileName={dispatchFileName} inputRef={dispatchRef}
          onChange={filialForcada?handleDispatchFile:()=>toast("Selecione a filial antes de escolher o arquivo!","warning")}
          label={filialForcada?"Clique para selecionar a planilha de deslocamentos":"⚠️ Selecione a filial acima primeiro"} />
        {dispatchError&&<div style={{ marginTop:12,padding:"10px 14px",borderRadius:10,background:"#ef444420",border:"1px solid #ef444440",color:"#f87171",fontSize:12 }}>⚠️ {dispatchError}</div>}
        {dispatchPreview&&(
          <div style={{ marginTop:16 }}>
            <div style={{ fontSize:12,color:"rgba(255,255,255,0.4)",marginBottom:10 }}>
              ✅ <strong style={{ color:"#34d399" }}>{dispatchPreview.normais} deslocamentos normais</strong>
              {dispatchPreview.portaria>0&&<span style={{ marginLeft:8,color:"#a78bfa" }}>+ {dispatchPreview.portaria} Portaria Inteligente</span>}
            </div>
            <div style={{ marginBottom:12,display:"flex",flexWrap:"wrap",gap:6 }}>
              {Object.entries(dispatchPreview.mesesNoArquivo||{}).map(([mk,qt])=>{
                const jaImportado=dispatchPreview.mesesJaImportados?.[mk];
                return (
                  <div key={mk} style={{ display:"flex",alignItems:"center",gap:6,padding:"5px 12px",borderRadius:99,fontSize:11,fontWeight:700,border:jaImportado?"1px solid rgba(251,146,60,0.5)":"1px solid rgba(52,211,153,0.4)",background:jaImportado?"rgba(251,146,60,0.1)":"rgba(52,211,153,0.08)",color:jaImportado?"#fb923c":"#34d399" }}>
                    {jaImportado?"⚠️":"🆕"} {monthLabel(mk)} <span style={{ opacity:0.7 }}>({qt} registros)</span>
                    {jaImportado&&<span style={{ fontSize:10,opacity:0.8 }}>— já importado!</span>}
                  </div>
                );
              })}
            </div>
            {Object.keys(dispatchPreview.mesesJaImportados||{}).length>0&&(
              <div style={{ marginBottom:12,padding:"10px 14px",borderRadius:10,background:"rgba(251,146,60,0.1)",border:"1px solid rgba(251,146,60,0.35)",color:"#fb923c",fontSize:12,lineHeight:1.6 }}>
                ⚠️ <strong>Atenção:</strong> {Object.keys(dispatchPreview.mesesJaImportados).map(mk=>monthLabel(mk)).join(", ")} já {Object.keys(dispatchPreview.mesesJaImportados).length===1?"foi importado":"foram importados"} anteriormente. Importar novamente vai <strong>duplicar</strong> os registros.
              </div>
            )}
            <div style={{ display:"flex",gap:10,marginTop:14 }}>
              <LoadingBtn
                onClick={confirmDispatches}
                loading={importandoDespachos}
                color={Object.keys(dispatchPreview.mesesJaImportados||{}).length>0?"#fb923c":"#818cf8"}
                style={{ flex:1,padding:10,borderRadius:10 }}>
                {Object.keys(dispatchPreview.mesesJaImportados||{}).length>0?"⚠️ Importar mesmo assim":"✅ Adicionar"} — {dispatchPreview.rows.length} registros
              </LoadingBtn>
              <button onClick={()=>{ setDispatchPreview(null); setDispatchFileName(""); if(dispatchRef.current)dispatchRef.current.value=""; }}
                style={{ padding:"10px 16px",borderRadius:10,border:"1px solid rgba(255,255,255,0.1)",background:"transparent",color:"rgba(255,255,255,0.4)",fontSize:13,cursor:"pointer" }}>
                Cancelar
              </button>
            </div>
          </div>
        )}
      </div>
      <MensalidadesPadraoCard clients={clients} supabaseClient={supabaseClient} onRefresh={onRefresh} />
      <div style={{ borderRadius:12,border:"1px solid rgba(255,255,255,0.06)",background:"rgba(255,255,255,0.02)",padding:"14px 18px" }}>
        <div style={{ fontSize:11,color:"rgba(255,255,255,0.25)",lineHeight:1.8 }}>
          💡 Importe primeiro os <strong style={{ color:"#38bdf8" }}>clientes</strong>, depois os <strong style={{ color:"#818cf8" }}>deslocamentos</strong>. O cruzamento é feito por <strong style={{ color:"rgba(255,255,255,0.4)" }}>Código + Filial</strong>.
        </div>
      </div>
    </div>
  );
}
</script>
<script type="text/babel" data-presets="react">
// ─── Clientes Tab ─────────────────────────────────────────────────────────────
function ClientesTab({ clients, dispatches, supabaseClient, onRefresh, isAdmin }) {
  const [busca, setBusca]             = useState("");
  const [filialFiltro, setFilialFiltro] = useState("Todas");
  const [cidadeFiltro, setCidadeFiltro] = useState("Todas");
  const [statusFiltro, setStatusFiltro] = useState("Todos");
  const [mesFiltro, setMesFiltro]     = useState("Todos");
  const [modalNovoCliente, setModalNovoCliente] = useState(false);
  const [editando, setEditando]       = useState(null);
  const [salvando, setSalvando]       = useState(false);
  const FILIAIS = ["SERVIS CEARÁ","SERVIS AMAZONAS","SERVIS MARANHÃO","SECOPI PIAUÍ","SECOPI PICOS","SECOPI PARNAÍBA","1 P3 SOLUCOES","2 PROGUARD","Maver Monitoramento","SIDERALTECH","VISION SEGURANCA","OVERTEC","3 LUXUS SERVICOS E TECNOLOGIA LTDA","4 PRIORIDADE SERVICOS TERCEIRIZADOS LTDA","PERES MONITORAMENTO"];

  useEffect(()=>{ setCidadeFiltro("Todas"); },[filialFiltro]);

  const cidadesDisponiveis = useMemo(()=>{
    const base = filialFiltro==="Todas"?clients:clients.filter(c=>c.filial===filialFiltro);
    const cidades = new Set(base.map(c=>String(c.cidade||"").trim().toUpperCase()).filter(Boolean));
    if (cidades.size<=1) return [];
    return ["Todas",...Array.from(cidades).sort()];
  },[clients,filialFiltro]);

  const mesesDisponiveis = useMemo(()=>{
    const s=new Set();
    for (const d of dispatches) { const dt=parseDataHora(d.data_hora); if (dt) s.add(getMonthKey(dt)); }
    return ["Todos",...Array.from(s).filter(Boolean).sort().reverse()];
  },[dispatches]);

  const dispMap = useMemo(()=>{
    const m={};
    for (const d of dispatches.filter(x=>!x.portaria_inteligente)) {
      if (mesFiltro!=="Todos") { const dt=parseDataHora(d.data_hora); if (!dt||getMonthKey(dt)!==mesFiltro) continue; }
      const k=`${d.codigo_cliente}||${d.filial}`;
      m[k]=(m[k]||0)+1;
    }
    return m;
  },[dispatches,mesFiltro]);

  const filiais = useMemo(()=>{ const s=new Set(clients.map(c=>c.filial).filter(Boolean)); return ["Todas",...Array.from(s).sort()]; },[clients]);

  const filtrados = useMemo(()=>{
    const buscaNorm=busca.toLowerCase().replace(/\s|^0+/g,"");
    return clients.filter(c=>{
      if (filialFiltro!=="Todas"&&c.filial!==filialFiltro) return false;
      if (cidadeFiltro!=="Todas"&&String(c.cidade||"").trim().toUpperCase()!==cidadeFiltro) return false;
      if (statusFiltro==="Ativos"&&c.status!=="ativo") return false;
      if (statusFiltro==="Inativos"&&c.status!=="inativo") return false;
      if (busca) {
        const nome=(c.nome_cliente||"").toLowerCase();
        const cod=String(c.codigo_cliente||"").replace(/^0+/,"");
        if (!nome.includes(busca.toLowerCase())&&!cod.includes(buscaNorm)) return false;
      }
      return true;
    });
  },[clients,busca,filialFiltro,cidadeFiltro,statusFiltro]);

  async function toggleStatus(c) {
    const novoStatus = c.status==="ativo"?"inativo":"ativo";
    try {
      await supaQuery(()=>supabaseClient.from("clients").update({ status:novoStatus }).eq("codigo_cliente",c.codigo_cliente));
      toast(`Cliente ${novoStatus==="ativo"?"ativado":"inativado"} com sucesso!`, "success");
      onRefresh();
    } catch(e) {
      toast("Erro ao alterar status: " + e.message, "error");
    }
  }

  async function salvarNovoCliente(dados) {
    setSalvando(true);
    try {
      await supaQuery(()=>supabaseClient.from("clients").upsert([{
        codigo_cliente:dados.codigo, nome_cliente:dados.nome, filial:dados.filial,
        mensalidade:parseFloat(dados.mensalidade)||0, status:"ativo",
      }],{ onConflict:"codigo_cliente,filial" }));
      setModalNovoCliente(false);
      toast("Cliente salvo com sucesso!", "success");
      onRefresh();
    } catch(e) {
      toast("Erro ao salvar: " + (e.message||"tente novamente"), "error");
    } finally {
      setSalvando(false);
    }
  }

  async function salvarEdicao(dados) {
    setSalvando(true);
    try {
      await supaQuery(()=>supabaseClient.from("clients")
        .update({ nome_cliente:dados.nome, mensalidade:parseFloat(String(dados.mensalidade).replace(",","."))||0 })
        .eq("codigo_cliente",editando.codigo_cliente)
      );
      setEditando(null);
      toast("Cliente atualizado com sucesso!", "success");
      onRefresh();
    } catch(e) {
      toast("Erro ao salvar: " + (e.message||"tente novamente"), "error");
    } finally {
      setSalvando(false);
    }
  }

  function exportarCSV() {
    const header="Código,Nome,Filial,Mensalidade,Status,Deslocamentos";
    const rows=filtrados.map(c=>{
      const desl=dispMap[`${c.codigo_cliente}||${c.filial}`]||0;
      return `${c.codigo_cliente},"${(c.nome_cliente||"").replace(/"/g,'""')}","${c.filial}",${c.mensalidade||0},${c.status},${desl}`;
    });
    const csv=[header,...rows].join("\n");
    const blob=new Blob([csv],{ type:"text/csv;charset=utf-8;" });
    const url=URL.createObjectURL(blob);
    const a=document.createElement("a"); a.href=url; a.download="clientes.csv"; a.click();
    URL.revokeObjectURL(url);
    toast("CSV exportado com sucesso!", "success");
  }

  const iStyle={ width:"100%",padding:"9px 12px",background:"rgba(255,255,255,0.06)",border:"1px solid rgba(255,255,255,0.1)",borderRadius:8,color:"#fff",fontSize:13,outline:"none" };

  return (
    <div>
      <div style={{ display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:20,flexWrap:"wrap",gap:12 }}>
        <div>
          <div style={{ fontSize:20,fontWeight:700 }}>👥 Clientes</div>
          <div style={{ fontSize:12,color:"rgba(255,255,255,0.4)",marginTop:2 }}>{filtrados.length} de {clients.length} clientes</div>
        </div>
        <div style={{ display:"flex",gap:10 }}>
          <button onClick={exportarCSV} style={{ background:"rgba(52,211,153,0.15)",border:"1px solid rgba(52,211,153,0.3)",color:"#34d399",borderRadius:10,padding:"8px 16px",cursor:"pointer",fontSize:13,fontWeight:600 }}>⬇ Exportar CSV</button>
          <button onClick={()=>setModalNovoCliente(true)} style={{ background:"#38bdf8",border:"none",color:"#000",borderRadius:10,padding:"8px 16px",cursor:"pointer",fontSize:13,fontWeight:700 }}>+ Novo Cliente</button>
        </div>
      </div>
      <div style={{ display:"flex",gap:10,marginBottom:16,flexWrap:"wrap" }}>
        <input placeholder="Buscar por nome ou código..." value={busca} onChange={e=>setBusca(e.target.value)} style={{ ...iStyle,flex:1,minWidth:200 }} />
        <select value={filialFiltro} onChange={e=>setFilialFiltro(e.target.value)} style={{ ...iStyle,width:"auto" }}>{filiais.map(f=><option key={f} value={f}>{f}</option>)}</select>
        {cidadesDisponiveis.length>0&&(
          <select value={cidadeFiltro} onChange={e=>setCidadeFiltro(e.target.value)} style={{ ...iStyle,width:"auto" }}>
            {cidadesDisponiveis.map(c=><option key={c} value={c}>{c==="Todas"?"🏙 Todas as cidades":`🏙 ${c}`}</option>)}
          </select>
        )}
        <select value={statusFiltro} onChange={e=>setStatusFiltro(e.target.value)} style={{ ...iStyle,width:"auto" }}>
          {["Todos","Ativos","Inativos"].map(s=><option key={s} value={s}>{s}</option>)}
        </select>
        <select value={mesFiltro} onChange={e=>setMesFiltro(e.target.value)} style={{ ...iStyle,width:"auto",borderColor:mesFiltro!=="Todos"?"rgba(251,146,60,0.5)":"rgba(255,255,255,0.1)",color:mesFiltro!=="Todos"?"#fb923c":"#fff" }}>
          {mesesDisponiveis.map(m=><option key={m} value={m}>{m==="Todos"?"📅 Todos os meses":`📅 ${monthLabel(m)}`}</option>)}
        </select>
      </div>
      <Card style={{ overflow:"hidden" }}>
        <div style={{ overflowX:"auto" }}>
          <table style={{ width:"100%",borderCollapse:"collapse",fontSize:13 }}>
            <thead>
              <tr style={{ borderBottom:"1px solid rgba(255,255,255,0.07)" }}>
                {["Nome","Código","Filial","Cidade","Mensalidade",mesFiltro!=="Todos"?`Disparos ${monthLabel(mesFiltro)}`:"Deslocamentos","Status",""].map((h,i)=>(
                  <th key={i} style={{ padding:"12px 16px",textAlign:i===0?"left":"center",color:"rgba(255,255,255,0.4)",fontWeight:600,fontSize:11,letterSpacing:0.5,whiteSpace:"nowrap" }}>{h}</th>
                ))}
              </tr>
            </thead>
            <tbody>
              {filtrados.length===0&&<tr><td colSpan={8} style={{ padding:40,textAlign:"center",color:"rgba(255,255,255,0.3)" }}>Nenhum cliente encontrado</td></tr>}
              {filtrados.map((c,i)=>{
                const desl=dispMap[`${c.codigo_cliente}||${c.filial}`]||0;
                const ativo=c.status!=="inativo";
                return (
                  <tr key={i} style={{ borderBottom:"1px solid rgba(255,255,255,0.04)",opacity:ativo?1:0.45,transition:"opacity 0.2s" }}>
                    <td style={{ padding:"12px 16px" }}><div style={{ fontWeight:600,color:ativo?"#fff":"rgba(255,255,255,0.5)" }}>{c.nome_cliente||"—"}</div></td>
                    <td style={{ padding:"12px 16px",textAlign:"center",color:"rgba(255,255,255,0.4)",fontFamily:"monospace" }}>{c.codigo_cliente}</td>
                    <td style={{ padding:"12px 16px",textAlign:"center",color:"rgba(255,255,255,0.6)",fontSize:12 }}>{c.filial}</td>
                    <td style={{ padding:"12px 16px",textAlign:"center",color:"rgba(255,255,255,0.4)",fontSize:12 }}>{c.cidade||"—"}</td>
                    <td style={{ padding:"12px 16px",textAlign:"center",color:c.mensalidade>0?"#34d399":"rgba(255,255,255,0.3)" }}>
                      {c.mensalidade>0?`R$ ${Number(c.mensalidade).toLocaleString("pt-BR",{minimumFractionDigits:2})}`:"—"}
                    </td>
                    <td style={{ padding:"12px 16px",textAlign:"center",color:desl>0?"#f472b6":"rgba(255,255,255,0.3)",fontWeight:desl>0?700:400 }}>{desl||"—"}</td>
                    <td style={{ padding:"12px 16px",textAlign:"center" }}>
                      <span style={{ fontSize:11,fontWeight:700,padding:"3px 10px",borderRadius:99,background:ativo?"rgba(52,211,153,0.15)":"rgba(239,68,68,0.15)",color:ativo?"#34d399":"#f87171" }}>
                        {ativo?"ATIVO":"INATIVO"}
                      </span>
                    </td>
                    <td style={{ padding:"12px 16px",textAlign:"center" }}>
                      <div style={{ display:"flex",gap:6,justifyContent:"center" }}>
                        <button onClick={()=>setEditando(c)} style={{ background:"rgba(56,189,248,0.1)",border:"1px solid rgba(56,189,248,0.2)",color:"#38bdf8",borderRadius:6,padding:"4px 10px",cursor:"pointer",fontSize:11 }}>✏️ Editar</button>
                        <button onClick={()=>toggleStatus(c)} style={{ background:ativo?"rgba(239,68,68,0.1)":"rgba(52,211,153,0.1)",border:ativo?"1px solid rgba(239,68,68,0.2)":"1px solid rgba(52,211,153,0.2)",color:ativo?"#f87171":"#34d399",borderRadius:6,padding:"4px 10px",cursor:"pointer",fontSize:11 }}>
                          {ativo?"🔴 Inativar":"🟢 Ativar"}
                        </button>
                      </div>
                    </td>
                  </tr>
                );
              })}
              {filtrados.length>0&&(()=>{
                const totalDisparos=filtrados.reduce((s,c)=>s+(dispMap[`${c.codigo_cliente}||${c.filial}`]||0),0);
                const totalMens=filtrados.reduce((s,c)=>s+(parseFloat(c.mensalidade)||0),0);
                return (
                  <tr style={{ borderTop:"2px solid rgba(255,255,255,0.12)",background:"rgba(255,255,255,0.04)" }}>
                    <td style={{ padding:"13px 16px" }}>
                      <div style={{ fontSize:11,fontWeight:700,color:"rgba(255,255,255,0.5)",textTransform:"uppercase",letterSpacing:"0.08em" }}>Total — {filtrados.length} clientes</div>
                    </td>
                    <td colSpan={3}></td>
                    <td style={{ padding:"13px 16px",textAlign:"center",fontWeight:800,color:"#34d399",fontSize:14 }}>{totalMens>0?formatCurrency(totalMens):"—"}</td>
                    <td style={{ padding:"13px 16px",textAlign:"center",fontWeight:800,color:"#f472b6",fontSize:14 }}>{totalDisparos.toLocaleString("pt-BR")}</td>
                    <td colSpan={2}></td>
                  </tr>
                );
              })()}
            </tbody>
          </table>
        </div>
      </Card>
      {modalNovoCliente&&<ModalFormCliente titulo="Novo Cliente" filiais={FILIAIS} onSalvar={salvarNovoCliente} onFechar={()=>setModalNovoCliente(false)} salvando={salvando} />}
      {editando&&<ModalFormCliente titulo="Editar Cliente" filiais={FILIAIS} inicial={editando} onSalvar={salvarEdicao} onFechar={()=>setEditando(null)} salvando={salvando} bloqueaCodigo={true} bloqueaFilial={true} />}
    </div>
  );
}

function ModalFormCliente({ titulo, filiais, inicial, onSalvar, onFechar, salvando, bloqueaCodigo, bloqueaFilial }) {
  const [codigo, setCodigo] = useState(inicial?.codigo_cliente||"");
  const [nome, setNome]     = useState(inicial?.nome_cliente||"");
  const [filial, setFilial] = useState(inicial?.filial||filiais[0]);
  const [mens, setMens]     = useState(inicial?.mensalidade||"");
  const iStyle={ width:"100%",padding:"9px 12px",background:"rgba(255,255,255,0.06)",border:"1px solid rgba(255,255,255,0.1)",borderRadius:8,color:"#fff",fontSize:13,outline:"none",marginTop:6 };
  return (
    <div style={{ position:"fixed",inset:0,background:"rgba(0,0,0,0.75)",zIndex:2000,display:"flex",alignItems:"center",justifyContent:"center",padding:16 }} onClick={onFechar}>
      <div style={{ background:"#0f172a",border:"1px solid rgba(255,255,255,0.1)",borderRadius:20,width:"100%",maxWidth:460,padding:28 }} onClick={e=>e.stopPropagation()}>
        <div style={{ fontSize:16,fontWeight:700,marginBottom:20 }}>{titulo}</div>
        <div style={{ display:"flex",flexDirection:"column",gap:14 }}>
          {[
            { label:"CÓDIGO", key:"codigo", val:codigo, set:setCodigo, disabled:bloqueaCodigo, placeholder:"Ex: 12345" },
            { label:"NOME DO CLIENTE", key:"nome", val:nome, set:setNome, placeholder:"Ex: Condomínio Exemplo" },
          ].map(({ label,key,val,set,disabled,placeholder })=>(
            <div key={key}>
              <label style={{ fontSize:11,color:"rgba(255,255,255,0.4)",letterSpacing:0.5 }}>{label}</label>
              <input value={val} onChange={e=>set(e.target.value)} disabled={disabled} placeholder={placeholder} style={{ ...iStyle,opacity:disabled?0.5:1 }} />
            </div>
          ))}
          <div>
            <label style={{ fontSize:11,color:"rgba(255,255,255,0.4)",letterSpacing:0.5 }}>FILIAL</label>
            <select value={filial} onChange={e=>setFilial(e.target.value)} disabled={bloqueaFilial} style={{ ...iStyle,opacity:bloqueaFilial?0.5:1 }}>
              {filiais.map(f=><option key={f} value={f}>{f}</option>)}
            </select>
          </div>
          <div>
            <label style={{ fontSize:11,color:"rgba(255,255,255,0.4)",letterSpacing:0.5 }}>MENSALIDADE (R$)</label>
            <input value={mens} onChange={e=>setMens(e.target.value)} placeholder="Ex: 150.00" type="number" style={iStyle} />
          </div>
        </div>
        <div style={{ display:"flex",gap:10,justifyContent:"flex-end",marginTop:24 }}>
          <button onClick={onFechar} style={{ background:"rgba(255,255,255,0.06)",border:"1px solid rgba(255,255,255,0.1)",color:"#fff",borderRadius:8,padding:"8px 18px",cursor:"pointer",fontSize:13 }}>Cancelar</button>
          <LoadingBtn onClick={()=>onSalvar({ codigo,nome,filial,mensalidade:mens })} loading={salvando} disabled={!codigo||!nome}>
            Salvar
          </LoadingBtn>
        </div>
      </div>
    </div>
  );
}

// ─── ConfigTab ────────────────────────────────────────────────────────────────
function ConfigTab({ onRefresh }) {
  const [custoFiscal, setCustoFiscal]   = useState(CUSTO_FISCAL);
  const [filiais, setFiliais]           = useState([]);
  const [loading, setLoading]           = useState(true);
  const [salvandoCusto, setSalvandoCusto] = useState(false);
  const [editandoFilial, setEditandoFilial] = useState(null);
  const [salvandoFilial, setSalvandoFilial] = useState(false);
  const [novaFilial, setNovaFilial]     = useState({ chave:"", nome:"", nome_raw:"" });
  const [showNovaFilial, setShowNovaFilial] = useState(false);
  const [salvandoNova, setSalvandoNova] = useState(false);

  useEffect(() => { carregarDadosConfig(); }, []);

  async function carregarDadosConfig() {
    setLoading(true);
    try {
      const [{ data: config }, { data: fils }] = await Promise.all([
        supabaseClient.from("config").select("*").eq("id","global").single(),
        supabaseClient.from("filiais").select("*").order("ordem"),
      ]);
      if (config?.vtr_cost) setCustoFiscal(parseFloat(config.vtr_cost));
      if (fils) setFiliais(fils);
    } catch(e) {
      toast("Erro ao carregar configurações: " + e.message, "error");
    } finally {
      setLoading(false);
    }
  }

  async function salvarCusto() {
    setSalvandoCusto(true);
    try {
      await supaQuery(() =>
        supabaseClient.from("config")
          .update({ vtr_cost: parseFloat(custoFiscal), updated_at: new Date().toISOString() })
          .eq("id","global")
      );
      CUSTO_FISCAL = parseFloat(custoFiscal);
      toast(`✅ Custo atualizado para R$ ${parseFloat(custoFiscal).toFixed(2)}!`, "success");
      await onRefresh();
    } catch(e) {
      toast("Erro ao salvar custo: " + e.message, "error");
    } finally {
      setSalvandoCusto(false);
    }
  }

  async function salvarFilial(f) {
    setSalvandoFilial(true);
    try {
      await supaQuery(() =>
        supabaseClient.from("filiais")
          .update({ nome: f.nome, nome_raw: f.nome_raw, ativo: f.ativo, updated_at: new Date().toISOString() })
          .eq("id", f.id)
      );
      // Atualiza cache local
      FILIAIS_DB = FILIAIS_DB.map(fb => fb.id === f.id ? { ...fb, ...f } : fb);
      toast("Filial atualizada com sucesso!", "success");
      setEditandoFilial(null);
      await carregarDadosConfig();
    } catch(e) {
      toast("Erro ao salvar filial: " + e.message, "error");
    } finally {
      setSalvandoFilial(false);
    }
  }

  async function toggleAtivo(f) {
    try {
      await supaQuery(() =>
        supabaseClient.from("filiais")
          .update({ ativo: !f.ativo, updated_at: new Date().toISOString() })
          .eq("id", f.id)
      );
      FILIAIS_DB = FILIAIS_DB.map(fb => fb.id === f.id ? { ...fb, ativo: !f.ativo } : fb);
      toast(`Filial ${!f.ativo ? "ativada" : "desativada"}!`, "success");
      await carregarDadosConfig();
    } catch(e) {
      toast("Erro: " + e.message, "error");
    }
  }

  async function salvarNovaFilial() {
    if (!novaFilial.chave || !novaFilial.nome) {
      toast("Preencha ao menos a Chave e o Nome.", "warning");
      return;
    }
    setSalvandoNova(true);
    try {
      const maxOrdem = Math.max(...filiais.map(f => f.ordem || 0), 0);
      await supaQuery(() =>
        supabaseClient.from("filiais").insert([{
          chave:    novaFilial.chave.trim(),
          nome:     novaFilial.nome.trim(),
          nome_raw: novaFilial.nome_raw.trim() || novaFilial.nome.trim(),
          ativo:    true,
          ordem:    maxOrdem + 1,
        }])
      );
      toast("Nova filial cadastrada!", "success");
      setNovaFilial({ chave:"", nome:"", nome_raw:"" });
      setShowNovaFilial(false);
      await carregarConfigBanco();
      await carregarDadosConfig();
    } catch(e) {
      toast("Erro ao cadastrar filial: " + (e.message || "chave pode já existir"), "error");
    } finally {
      setSalvandoNova(false);
    }
  }

  const iStyle = { width:"100%", padding:"9px 12px", background:"rgba(255,255,255,0.06)", border:"1px solid rgba(255,255,255,0.12)", borderRadius:8, color:"#fff", fontSize:13, outline:"none" };

  if (loading) return (
    <div style={{ display:"flex", flexDirection:"column", gap:16 }}>
      {[1,2,3].map(i => <Skeleton key={i} height={60} radius={12} />)}
    </div>
  );

  return (
    <div>
      <div style={{ fontSize:20, fontWeight:700, marginBottom:4 }}>⚙️ Configurações</div>
      <div style={{ fontSize:12, color:"rgba(255,255,255,0.4)", marginBottom:24 }}>Gerencie custo fiscal e filiais sem precisar alterar o código</div>

      {/* ── Custo Fiscal ── */}
      <Card style={{ marginBottom:20 }}>
        <div style={{ padding:"16px 20px", borderBottom:"1px solid rgba(255,255,255,0.07)" }}>
          <SectionLabel>💰 Custo por Deslocamento</SectionLabel>
          <p style={{ fontSize:11, color:"rgba(255,255,255,0.3)", margin:"-8px 0 0" }}>
            Valor usado para calcular o custo operacional de todos os clientes
          </p>
        </div>
        <div style={{ padding:20 }}>
          <div style={{ display:"flex", alignItems:"center", gap:16, flexWrap:"wrap" }}>
            <div style={{ flex:1, minWidth:200 }}>
              <label style={{ fontSize:11, fontWeight:600, textTransform:"uppercase", letterSpacing:"0.08em", color:"rgba(255,255,255,0.4)", display:"block", marginBottom:8 }}>
                Valor em R$
              </label>
              <div style={{ display:"flex", alignItems:"center", gap:10 }}>
                <span style={{ fontSize:18, color:"#34d399", fontWeight:700 }}>R$</span>
                <input
                  type="number" step="0.01" min="0"
                  value={custoFiscal}
                  onChange={e => setCustoFiscal(e.target.value)}
                  style={{ ...iStyle, width:140, fontSize:20, fontWeight:800, color:"#34d399", textAlign:"center" }}
                />
              </div>
            </div>
            <div style={{ display:"flex", flexDirection:"column", gap:6 }}>
              <div style={{ fontSize:11, color:"rgba(255,255,255,0.35)" }}>Valor atual no banco</div>
              <div style={{ fontSize:24, fontWeight:800, color:"#38bdf8" }}>R$ {CUSTO_FISCAL.toFixed(2).replace(".",",")}</div>
            </div>
            <LoadingBtn onClick={salvarCusto} loading={salvandoCusto} disabled={parseFloat(custoFiscal) === CUSTO_FISCAL}>
              💾 Salvar Custo
            </LoadingBtn>
          </div>
          <div style={{ marginTop:14, padding:"10px 14px", borderRadius:8, background:"rgba(56,189,248,0.06)", border:"1px solid rgba(56,189,248,0.15)", fontSize:11, color:"rgba(255,255,255,0.4)", lineHeight:1.7 }}>
            ℹ️ Alterar este valor recalcula automaticamente o custo operacional de <strong style={{ color:"#fff" }}>todos os clientes</strong> em todos os dashboards na próxima vez que a página for carregada.
          </div>
        </div>
      </Card>

      {/* ── Filiais ── */}
      <Card>
        <div style={{ padding:"16px 20px", borderBottom:"1px solid rgba(255,255,255,0.07)", display:"flex", justifyContent:"space-between", alignItems:"center", flexWrap:"wrap", gap:12 }}>
          <div>
            <SectionLabel>🏢 Filiais Cadastradas</SectionLabel>
            <p style={{ fontSize:11, color:"rgba(255,255,255,0.3)", margin:"-8px 0 0" }}>
              {filiais.filter(f=>f.ativo).length} ativas · {filiais.filter(f=>!f.ativo).length} inativas
            </p>
          </div>
          <button
            onClick={() => setShowNovaFilial(s => !s)}
            style={{ padding:"8px 16px", borderRadius:10, border:"1px solid rgba(56,189,248,0.3)", background:"rgba(56,189,248,0.1)", color:"#38bdf8", fontSize:12, fontWeight:700, cursor:"pointer" }}>
            {showNovaFilial ? "Cancelar" : "+ Nova Filial"}
          </button>
        </div>

        {/* Form nova filial */}
        {showNovaFilial && (
          <div style={{ padding:"16px 20px", borderBottom:"1px solid rgba(255,255,255,0.07)", background:"rgba(56,189,248,0.04)" }}>
            <div style={{ fontSize:12, fontWeight:700, color:"#38bdf8", marginBottom:12 }}>➕ Nova Filial</div>
            <div style={{ display:"grid", gridTemplateColumns:"1fr 1fr 1fr auto", gap:12, alignItems:"flex-end" }}>
              <div>
                <label style={{ fontSize:10, fontWeight:700, textTransform:"uppercase", letterSpacing:"0.08em", color:"rgba(255,255,255,0.35)", display:"block", marginBottom:6 }}>Chave interna *</label>
                <input value={novaFilial.chave} onChange={e=>setNovaFilial(f=>({...f,chave:e.target.value}))} placeholder="Ex: NOVA FILIAL" style={iStyle} />
                <div style={{ fontSize:10, color:"rgba(255,255,255,0.25)", marginTop:4 }}>Usada internamente — não pode mudar depois</div>
              </div>
              <div>
                <label style={{ fontSize:10, fontWeight:700, textTransform:"uppercase", letterSpacing:"0.08em", color:"rgba(255,255,255,0.35)", display:"block", marginBottom:6 }}>Nome exibição *</label>
                <input value={novaFilial.nome} onChange={e=>setNovaFilial(f=>({...f,nome:e.target.value}))} placeholder="Ex: Nova Filial" style={iStyle} />
              </div>
              <div>
                <label style={{ fontSize:10, fontWeight:700, textTransform:"uppercase", letterSpacing:"0.08em", color:"rgba(255,255,255,0.35)", display:"block", marginBottom:6 }}>Nome na planilha</label>
                <input value={novaFilial.nome_raw} onChange={e=>setNovaFilial(f=>({...f,nome_raw:e.target.value}))} placeholder="Como aparece no Excel" style={iStyle} />
              </div>
              <LoadingBtn onClick={salvarNovaFilial} loading={salvandoNova} style={{ whiteSpace:"nowrap" }}>
                Cadastrar
              </LoadingBtn>
            </div>
          </div>
        )}

        {/* Lista de filiais */}
        <div style={{ overflowX:"auto" }}>
          <table style={{ width:"100%", borderCollapse:"collapse", fontSize:13 }}>
            <thead>
              <tr style={{ borderBottom:"1px solid rgba(255,255,255,0.07)" }}>
                {["Ordem","Chave Interna","Nome Exibição","Nome na Planilha","Status",""].map(h=>(
