<body>
  <div id="root"></div>
  <script type="text/babel" data-presets="react">
const { useState, useMemo, useRef, useEffect, useCallback } = React;
const supabaseClient = window._supabaseClient;

// ─── Constants (defaults — serão sobrescritos pelo banco) ────────────────────
let CUSTO_FISCAL = 48;
let FILIAIS_DB = [];
const CHART_COLORS = ["#38bdf8","#818cf8","#34d399","#fb923c","#f472b6","#a78bfa","#4ade80","#f43f5e","#06b6d4"];

// ─── Carrega config e filiais do banco ───────────────────────────────────────
async function carregarConfigBanco() {
  try {
    const [{ data: config }, { data: filiais }] = await Promise.all([
      supabaseClient.from("config").select("*").eq("id", "global").single(),
      supabaseClient.from("filiais").select("*").eq("ativo", true).order("ordem"),
    ]);
    if (config?.vtr_cost) CUSTO_FISCAL = parseFloat(config.vtr_cost);
    if (filiais?.length)  FILIAIS_DB   = filiais;
  } catch(e) {
    console.warn("Erro ao carregar config do banco, usando valores padrão:", e.message);
  }
}

// Retorna lista de chaves de filiais para selects
function getFiliaisKeys() {
  if (FILIAIS_DB.length > 0) return FILIAIS_DB.map(f => f.chave);
  return ["SERVIS CEARÁ","SERVIS AMAZONAS","SERVIS MARANHÃO","SECOPI TERESINA","SECOPI PICOS","SECOPI PARNAÍBA","1 P3 SOLUCOES","2 PROGUARD","3 LUXUS SERVICOS E TECNOLOGIA LTDA","4 PRIORIDADE SERVICOS TERCEIRIZADOS LTDA","PERES MONITORAMENTO","Maver Monitoramento","OVERTEC","SIDERALTECH","VISION SEGURANCA"];
}
// Retorna nome de exibição de uma filial
function getNomeFilial(chave) {
  const f = FILIAIS_DB.find(f => f.chave === chave);
  return f ? f.nome : chave;
}
const STATUS_CONFIG = {
  "PREJUÍZO":  { bg:"#ef444420", text:"#f87171", border:"#ef444440", dot:"#f87171" },
  "RISCO":     { bg:"#f59e0b20", text:"#fbbf24", border:"#f59e0b40", dot:"#fbbf24" },
  "SAUDÁVEL":  { bg:"#10b98120", text:"#34d399", border:"#10b98140", dot:"#34d399" },
  "SEM DADOS": { bg:"#ffffff10", text:"rgba(255,255,255,0.3)", border:"#ffffff15", dot:"rgba(255,255,255,0.2)" },
};

// ─── Toast System ─────────────────────────────────────────────────────────────
let _toastId = 0;
let _setToasts = null;

function useToastSystem() {
  const [toasts, setToasts] = useState([]);
  useEffect(() => { _setToasts = setToasts; }, []);
  return toasts;
}

function toast(msg, type = "info", duration = 4000) {
  if (!_setToasts) return;
  const id = ++_toastId;
  _setToasts(prev => [...prev, { id, msg, type }]);
  setTimeout(() => {
    _setToasts(prev => prev.filter(t => t.id !== id));
  }, duration);
}

function ToastContainer({ toasts }) {
  const icons = { success:"✅", error:"❌", warning:"⚠️", info:"ℹ️" };
  if (!toasts.length) return null;
  return (
    <div className="toast-container">
      {toasts.map(t => (
        <div key={t.id} className={`toast toast-${t.type}`}>
          <span>{icons[t.type]}</span>
          <span>{t.msg}</span>
        </div>
      ))}
    </div>
  );
}

// ─── Helpers ──────────────────────────────────────────────────────────────────
function formatCurrency(v) {
  return new Intl.NumberFormat("pt-BR",{ style:"currency", currency:"BRL", minimumFractionDigits:0 }).format(v||0);
}
function formatSaldo(mensalidade, saldo) {
  if (!mensalidade) return "—";
  return formatCurrency(saldo);
}
function calcStatus(mensalidade, custo) {
  if (!mensalidade) return "SEM DADOS";
  const lucro = mensalidade - custo;
  if (lucro < 0) return "PREJUÍZO";
  if (lucro < mensalidade * 0.3) return "RISCO";
  return "SAUDÁVEL";
}
function limparEmpresa(raw, cidade) {
  if (!raw) return "";
  let s = String(raw).trim();
  s = s.replace(/\(.*?\)/g,"").trim();
  s = s.replace(/^\d+\.\s*/,"").trim();
  s = s.toUpperCase().trim();
  if (s.includes("CEARÁ")||s.includes("CEARA")||s==="CEARÁ"||s==="CEARA") return "SERVIS CEARÁ";
  if (s.includes("AMAZONAS")||s==="MANAUS") return "SERVIS AMAZONAS";
  if (s.includes("MARANHÃO")||s.includes("MARANHAO")) return "SERVIS MARANHÃO";
  if (s.includes("PIAUÍ")||s.includes("PIAUI")||s.includes("SECOPI")) {
    const c = String(cidade||"").toUpperCase().normalize("NFD").replace(/[\u0300-\u036f]/g,"");
    if (c.includes("PICOS")||c.includes("FLORIANO")||c.includes("VALENCA")) return "SECOPI PICOS";
    if (c.includes("PARNAI")||c.includes("LUIS CORREIA")||c.includes("CORREIA")) return "SECOPI PARNAÍBA";
    return "SECOPI TERESINA";
  }
  if (s.includes("P3")||s.includes("SOLUC")) return "1 P3 SOLUCOES";
  if (s.includes("PROGUARD")) return "2 PROGUARD";
  if (s.includes("MAVER")) return "Maver Monitoramento";
  if (s.includes("SIDERAL")) return "SIDERALTECH";
  if (s.includes("VISION")||s.includes("VISÃO")) return "VISION SEGURANCA";
  if (s.includes("OVERTEC")) return "OVERTEC";
  if (s.includes("LUXUS")) return "3 LUXUS SERVICOS E TECNOLOGIA LTDA";
  if (s.includes("PRIORIDADE")) return "4 PRIORIDADE SERVICOS TERCEIRIZADOS LTDA";
  if (s.includes("PERES")) return "PERES MONITORAMENTO";
  return s;
}
function limparFantasia(raw) {
  if (!raw) return "";
  let s = String(raw).trim();
  s = s.replace(/\s*\(.*?\)\s*$/,"").trim();
  s = s.replace(/^\(.*?\)\s*/,"").trim();
  return s;
}
function parseDataHora(str) {
  if (!str) return null;
  const m = String(str).match(/(\d{2})\/(\d{2})\/(\d{4})/);
  if (m) return new Date(`${m[3]}-${m[2]}-${m[1]}T00:00:00`);
  const d = new Date(str);
  return isNaN(d) ? null : d;
}
function getWeekKey(date) {
  if (!date) return null;
  const d = new Date(date);
  const day = d.getDay();
  const diff = (day===0 ? -6 : 1-day);
  d.setDate(d.getDate()+diff);
  return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,"0")}-${String(d.getDate()).padStart(2,"0")}`;
}
function weekLabel(key) {
  if (!key) return "—";
  const [y,m,d] = key.split("-");
  const start = new Date(`${y}-${m}-${d}T00:00:00`);
  const end = new Date(start); end.setDate(end.getDate()+6);
  const fmt = dt => `${String(dt.getDate()).padStart(2,"0")}/${String(dt.getMonth()+1).padStart(2,"0")}`;
  return `${fmt(start)} – ${fmt(end)}/${end.getFullYear()}`;
}
function getMonthKey(date) {
  if (!date) return null;
  const d = new Date(date);
  return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,"0")}`;
}
const MESES_PT = ["Jan","Fev","Mar","Abr","Mai","Jun","Jul","Ago","Set","Out","Nov","Dez"];
function monthLabel(key) {
  if (!key) return "—";
  const [y,m] = key.split("-");
  return `${MESES_PT[parseInt(m)-1]}/${y}`;
}

// ─── Supabase helper com retry e tratamento de erro ──────────────────────────
async function supaQuery(fn, tentativas = 3) {
  let ultimoErro = null;
  for (let i = 0; i < tentativas; i++) {
    try {
      const resultado = await fn();
      if (resultado.error) {
        ultimoErro = resultado.error;
        if (i < tentativas - 1) await new Promise(r => setTimeout(r, 600 * (i + 1)));
        continue;
      }
      return resultado;
    } catch (e) {
      ultimoErro = e;
      if (i < tentativas - 1) await new Promise(r => setTimeout(r, 600 * (i + 1)));
    }
  }
  throw ultimoErro || new Error("Falha na consulta ao banco de dados");
}

// ─── UI Components ────────────────────────────────────────────────────────────
function KPICard({ label, value, sub, accent, icon }) {
  return (
    <div style={{ position:"relative", overflow:"hidden", borderRadius:16, border:"1px solid rgba(255,255,255,0.08)", background:"rgba(255,255,255,0.04)", padding:20, boxShadow:`0 0 40px -10px ${accent}44` }}>
      <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", marginBottom:10 }}>
        <span style={{ fontSize:10, fontWeight:700, letterSpacing:"0.15em", textTransform:"uppercase", color:"rgba(255,255,255,0.35)" }}>{label}</span>
        <span style={{ fontSize:18 }}>{icon}</span>
      </div>
      <div style={{ fontSize:24, fontWeight:800, color:"#fff" }}>{value}</div>
      {sub && <div style={{ fontSize:11, color:"rgba(255,255,255,0.35)", marginTop:3 }}>{sub}</div>}
      <div style={{ position:"absolute", bottom:-16, right:-16, width:80, height:80, borderRadius:"50%", background:accent, opacity:0.12, filter:"blur(20px)" }} />
    </div>
  );
}
function StatusBadge({ status }) {
  const cfg = STATUS_CONFIG[status]||STATUS_CONFIG["SEM DADOS"];
  return (
    <span style={{ display:"inline-flex", alignItems:"center", gap:6, borderRadius:999, border:`1px solid ${cfg.border}`, background:cfg.bg, color:cfg.text, padding:"3px 10px", fontSize:11, fontWeight:700 }}>
      <span style={{ width:6, height:6, borderRadius:"50%", background:cfg.dot }} />{status}
    </span>
  );
}
function SectionLabel({ children }) {
  return (
    <div style={{ fontSize:10, fontWeight:700, letterSpacing:"0.15em", textTransform:"uppercase", color:"rgba(255,255,255,0.35)", marginBottom:16, display:"flex", alignItems:"center", gap:8 }}>
      <span style={{ height:1, width:16, background:"rgba(255,255,255,0.15)", display:"inline-block" }} />{children}
    </div>
  );
}
function TabBtn({ active, onClick, children, accent }) {
  return (
    <button onClick={onClick} style={{ padding:"9px 20px", borderRadius:10, fontSize:13, fontWeight:600, cursor:"pointer", border:active?`1px solid ${accent||"#38bdf8"}`:"1px solid rgba(255,255,255,0.08)", background:active?`${accent||"#38bdf8"}18`:"transparent", color:active?(accent||"#38bdf8"):"rgba(255,255,255,0.45)", transition:"all 0.15s" }}>
      {children}
    </button>
  );
}
function FilterBtn({ active, onClick, children }) {
  return (
    <button onClick={onClick} style={{ padding:"5px 14px", borderRadius:999, fontSize:11, fontWeight:600, cursor:"pointer", border:active?"1px solid #38bdf8":"1px solid rgba(255,255,255,0.1)", background:active?"rgba(56,189,248,0.15)":"rgba(255,255,255,0.04)", color:active?"#38bdf8":"rgba(255,255,255,0.45)", transition:"all 0.15s" }}>
      {children}
    </button>
  );
}
function EmptyState({ icon, title, sub }) {
  return (
    <div style={{ display:"flex", flexDirection:"column", alignItems:"center", justifyContent:"center", padding:"60px 20px", gap:12 }}>
      <div style={{ fontSize:40 }}>{icon}</div>
      <div style={{ fontSize:15, fontWeight:600, color:"rgba(255,255,255,0.4)" }}>{title}</div>
      {sub && <div style={{ fontSize:12, color:"rgba(255,255,255,0.2)", textAlign:"center", maxWidth:340, lineHeight:1.6 }}>{sub}</div>}
    </div>
  );
}
function Card({ children, style }) {
  return <div style={{ borderRadius:16, border:"1px solid rgba(255,255,255,0.08)", background:"rgba(255,255,255,0.04)", overflow:"hidden", ...style }}>{children}</div>;
}
function ColTag({ children, color }) {
  return <span style={{ display:"inline-flex", alignItems:"center", background:`${color}15`, border:`1px solid ${color}30`, borderRadius:6, padding:"2px 8px", fontSize:11, color, fontWeight:600, fontFamily:"monospace" }}>{children}</span>;
}

// ─── Botão com loading inline ────────────────────────────────────────────────
function LoadingBtn({ onClick, loading, disabled, children, style, color="#38bdf8", textColor="#000" }) {
  return (
    <button
      onClick={onClick}
      disabled={loading || disabled}
      className={loading ? "btn-loading" : ""}
      style={{ display:"flex", alignItems:"center", justifyContent:"center", gap:8, background:color, border:"none", color:textColor, borderRadius:8, padding:"8px 20px", cursor:loading||disabled?"not-allowed":"pointer", fontWeight:700, fontSize:13, opacity:disabled&&!loading?0.5:1, transition:"opacity 0.15s", ...style }}>
      {loading && <span className="btn-spinner" />}
      {children}
    </button>
  );
}

// ─── Skeleton loader ─────────────────────────────────────────────────────────
function Skeleton({ width="100%", height=16, radius=6, style={} }) {
  return (
    <div style={{ width, height, borderRadius:radius, background:"linear-gradient(90deg,rgba(255,255,255,0.05) 25%,rgba(255,255,255,0.1) 50%,rgba(255,255,255,0.05) 75%)", backgroundSize:"200% 100%", animation:"shimmer 1.5s infinite", ...style }} />
  );
}

// ─── Charts ───────────────────────────────────────────────────────────────────
function BarChart({ data, label, height=220 }) {
  const ref = useRef(null);
  const inst = useRef(null);
  useEffect(() => {
    if (!ref.current||!data?.length) return;
    if (inst.current) inst.current.destroy();
    inst.current = new Chart(ref.current, {
      type:"bar",
      data: { labels:data.map(d=>d.label), datasets:[{ label, data:data.map(d=>d.value), backgroundColor:CHART_COLORS.map(c=>c+"99"), borderColor:CHART_COLORS, borderWidth:1, borderRadius:6, borderSkipped:false }] },
      options: { responsive:true, maintainAspectRatio:false, plugins:{ legend:{display:false}, tooltip:{backgroundColor:"#0f172a",borderColor:"rgba(255,255,255,0.12)",borderWidth:1,titleColor:"#fff",bodyColor:"rgba(255,255,255,0.65)",padding:10} }, scales:{ x:{grid:{color:"rgba(255,255,255,0.04)"},ticks:{color:"rgba(255,255,255,0.4)",font:{size:10},maxRotation:35}}, y:{grid:{color:"rgba(255,255,255,0.06)"},ticks:{color:"rgba(255,255,255,0.4)",font:{size:10}},beginAtZero:true} }, animation:{duration:400} },
    });
    return () => { if (inst.current) inst.current.destroy(); };
  }, [JSON.stringify(data)]);
  if (!data?.length) return <div style={{ height, display:"flex", alignItems:"center", justifyContent:"center", color:"rgba(255,255,255,0.2)", fontSize:12 }}>Sem dados</div>;
  return <div style={{ position:"relative", height }}><canvas ref={ref} /></div>;
}
function DonutChart({ data, height=220 }) {
  const ref = useRef(null);
  const inst = useRef(null);
  useEffect(() => {
    if (!ref.current||!data?.length) return;
    if (inst.current) inst.current.destroy();
    inst.current = new Chart(ref.current, {
      type:"doughnut",
      data: { labels:data.map(d=>d.label), datasets:[{ data:data.map(d=>d.value), backgroundColor:CHART_COLORS.map(c=>c+"cc"), borderColor:"#080c14", borderWidth:3, hoverOffset:8 }] },
      options: { responsive:true, maintainAspectRatio:false, cutout:"62%", plugins:{ legend:{position:"right",labels:{color:"rgba(255,255,255,0.55)",font:{size:11},padding:10,boxWidth:12,usePointStyle:true}}, tooltip:{backgroundColor:"#0f172a",borderColor:"rgba(255,255,255,0.12)",borderWidth:1,titleColor:"#fff",bodyColor:"rgba(255,255,255,0.65)",padding:10} }, animation:{duration:400} },
    });
    return () => { if (inst.current) inst.current.destroy(); };
  }, [JSON.stringify(data)]);
  if (!data?.length) return <div style={{ height, display:"flex", alignItems:"center", justifyContent:"center", color:"rgba(255,255,255,0.2)", fontSize:12 }}>Sem dados</div>;
  return <div style={{ position:"relative", height }}><canvas ref={ref} /></div>;
}
function LineChart({ data, label, color="#38bdf8", height=220 }) {
  const ref = useRef(null);
  const inst = useRef(null);
  useEffect(() => {
    if (!ref.current||!data?.length) return;
    if (inst.current) inst.current.destroy();
    inst.current = new Chart(ref.current, {
      type:"line",
      data: { labels:data.map(d=>d.label), datasets:[{ label, data:data.map(d=>d.value), borderColor:color, backgroundColor:color+"18", fill:true, tension:0.4, pointBackgroundColor:color, pointRadius:4, pointHoverRadius:6 }] },
      options: { responsive:true, maintainAspectRatio:false, plugins:{ legend:{display:false}, tooltip:{backgroundColor:"#0f172a",borderColor:"rgba(255,255,255,0.12)",borderWidth:1,titleColor:"#fff",bodyColor:"rgba(255,255,255,0.65)",padding:10} }, scales:{ x:{grid:{color:"rgba(255,255,255,0.04)"},ticks:{color:"rgba(255,255,255,0.4)",font:{size:10}}}, y:{grid:{color:"rgba(255,255,255,0.06)"},ticks:{color:"rgba(255,255,255,0.4)",font:{size:10}},beginAtZero:true} }, animation:{duration:400} },
    });
    return () => { if (inst.current) inst.current.destroy(); };
  }, [JSON.stringify(data)]);
  if (!data?.length) return <div style={{ height, display:"flex", alignItems:"center", justifyContent:"center", color:"rgba(255,255,255,0.2)", fontSize:12 }}>Sem dados</div>;
  return <div style={{ position:"relative", height }}><canvas ref={ref} /></div>;
}

// ─── Paginação ────────────────────────────────────────────────────────────────
function Pagination({ total, page, perPage, onChange }) {
  const totalPages = Math.max(1, Math.ceil(total/perPage));
  if (totalPages<=1) return null;
  const pages = [];
  for (let i=1;i<=totalPages;i++) {
    if (i===1||i===totalPages||Math.abs(i-page)<=1) pages.push(i);
    else if (pages[pages.length-1]!=="…") pages.push("…");
  }
  return (
    <div className="pgn">
      <span className="pgn-info">Página {page} de {totalPages} · {total} registros</span>
      <button className="pgn-btn" disabled={page===1} onClick={()=>onChange(page-1)}>‹</button>
      {pages.map((p,i) => p==="…"
        ? <span key={i} style={{ color:"rgba(255,255,255,0.2)",fontSize:12,padding:"0 2px" }}>…</span>
        : <button key={p} className={`pgn-btn${page===p?" on":""}`} onClick={()=>onChange(p)}>{p}</button>
      )}
      <button className="pgn-btn" disabled={page===totalPages} onClick={()=>onChange(page+1)}>›</button>
    </div>
  );
}

function DropZone({ color, fileName, inputRef, onChange, label }) {
