{
  "rewrites": [
    { "source": "/config.js", "destination": "/api/config.js" }
  ],
  "headers": [
    {
      "source": "/api/config.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
